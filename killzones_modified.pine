//@version=5
indicator("KillZones & Sessions [Dynamic Time] | Custom Kill Zones" , 'Dynamic Kill Zones', overlay = true, max_bars_back = 5000, max_boxes_count = 500, max_labels_count = 500, max_lines_count = 500)

// import Sessions and KillZones Library
import TFlab/SessionAndKillZoneLibrary_TradingFinder/1 as Sess

// Global Setting
ShowMoreInfo = input.bool(false, 'Show More Info', inline = 'More' , group = 'Global Setting')
ColorMoreInfo = input.color(#0c3299, '', inline = 'More' , group = 'Global Setting')

//First Kill Zone - User Configurable
show_KZ1 = input(true, 'First Kill Zone Session',inline = 'ses1', group = 'First Kill Zone', tooltip = 'Configure your first kill zone time')
KZ1_SessTime = input.session('0700-0900', 'Session Time',  group = 'First Kill Zone')
KZ1_color = input.color(#fa7b05, '', inline = 'ses1', group = 'First Kill Zone')
show_KZ1_Kill = input(true, 'First Kill Zone', group = 'First Kill Zone')
KZ1_KillTime = input.session('0700-0900', 'Kill Zone Time', group = 'First Kill Zone')

//Second Kill Zone - User Configurable
show_KZ2 = input(true, 'Second Kill Zone Session',  inline = 'ses2', group = 'Second Kill Zone', tooltip = 'Configure your second kill zone time') 
KZ2_SessTime = input.session('1000-1300', 'Session Time',  group = 'Second Kill Zone')
KZ2_color = input.color(#118502, '', inline = 'ses2', group = 'Second Kill Zone')
show_KZ2_Kill = input(true, 'Second Kill Zone',  group = 'Second Kill Zone') 
KZ2_KillTime = input.session('1000-1300', 'Kill Zone Time', group = 'Second Kill Zone')

// Function to extract time from session string and format it nicely
formatSessionTime(sessionString) =>
    // Extract the time part (before any colon)
    timeOnly = str.split(sessionString, ":")[0]
    
    // Split start and end times
    times = str.split(timeOnly, "-")
    startTime = times[0]
    endTime = times[1]
    
    // Format start time
    startHour = str.tonumber(str.substring(startTime, 0, 2))
    startMin = str.substring(startTime, 2, 4)
    startFormatted = str.tostring(startHour) + ":" + startMin
    
    // Format end time  
    endHour = str.tonumber(str.substring(endTime, 0, 2))
    endMin = str.substring(endTime, 2, 4)
    endFormatted = str.tostring(endHour) + ":" + endMin
    
    // Return formatted string
    startFormatted + " - " + endFormatted

// Get dynamic labels based on user input times
KZ1_Label = formatSessionTime(KZ1_SessTime)
KZ2_Label = formatSessionTime(KZ2_SessTime)

// Call Sessions and KillZones Library with dynamic names
Sess.SessionDetector(KZ1_Label, KZ1_SessTime, KZ1_KillTime, show_KZ1, show_KZ1_Kill, 'Session', ShowMoreInfo, KZ1_color, ColorMoreInfo)
Sess.SessionDetector(KZ2_Label, KZ2_SessTime, KZ2_KillTime, show_KZ2, show_KZ2_Kill, 'Session', ShowMoreInfo, KZ2_color, ColorMoreInfo)