// © SZTrades - Custom Kill Zones Indicator
// Based on TFlab SessionAndKillZoneLibrary - Modified for personal use

//@version=5
indicator("SZTrades Kill Zones | PreMkt & NY" , 'SZTrades KZ', overlay = true, max_bars_back = 5000, max_boxes_count = 500, max_labels_count = 500, max_lines_count = 500)

// import Sessions and KillZones Library
import TFlab/SessionAndKillZoneLibrary_TradingFinder/1 as Sess

// Global Setting
ShowMoreInfo = input.bool(false, 'Show More Info', inline = 'More' , group = 'Global Setting')
ColorMoreInfo = input.color(#0c3299, '', inline = 'More' , group = 'Global Setting')

// Statistics Settings
ShowStatsTable = input.bool(true, 'Show Statistics Table', group = 'Statistics')
StatsLookback = input.int(5, 'Days to Show', minval = 1, maxval = 10, group = 'Statistics')
TablePosition = input.string('top_right', 'Table Position', options = ['top_left', 'top_center', 'top_right', 'middle_left', 'middle_center', 'middle_right', 'bottom_left', 'bottom_center', 'bottom_right'], group = 'Statistics')

//Session PreMkt (7:00-9:00 AM NY Time)
show_PreMktSess = input(true, 'PreMkt Session',inline = 'ses1', group = 'PreMkt Kill Zone', tooltip = 'PreMarket Kill Zone 7:00-9:00 AM NY Time')
PreMkt_SessTime = input.session('1100-1300', '',  group = 'PreMkt Kill Zone')
PreMkt_color = input.color(#fa7b05, '', inline = 'ses1', group = 'PreMkt Kill Zone')
show_PreMktKill = input(true, 'PreMkt Kill Zone', group = 'PreMkt Kill Zone')
PreMkt_KillTime = input.session('1100-1300', '', group = 'PreMkt Kill Zone')

//Session NY (10:00 AM - 1:30 PM NY Time)
show_NYSess = input(true, 'NY Session',  inline = 'ses2', group = 'NY Kill Zone', tooltip = 'New York Kill Zone 10:00 AM - 1:30 PM NY Time') 
NY_SessTime = input.session('1400-1730', '',  group = 'NY Kill Zone')
NY_color = input.color(#118502, '', inline = 'ses2', group = 'NY Kill Zone')
show_NYKill = input(true, 'NY Kill Zone',  group = 'NY Kill Zone') 
NY_KillTime = input.session('1400-1730', '', group = 'NY Kill Zone')

// Session Detection Variables
var bool inPreMktSession = false
var bool inNYSession = false
var float preMktOpen = na
var float preMktHigh = na
var float preMktLow = na
var float preMktClose = na
var float nyOpen = na
var float nyHigh = na
var float nyLow = na
var float nyClose = na

// Arrays to store historical data
var array<string> dates = array.new<string>()
var array<float> preMktRanges = array.new<float>()
var array<string> preMktDirections = array.new<string>()
var array<float> nyRanges = array.new<float>()
var array<string> nyDirections = array.new<string>()

// Check if we are in PreMkt session
preMktSession = not na(time(timeframe.period, PreMkt_SessTime))
nySession = not na(time(timeframe.period, NY_SessTime))

// PreMkt Session Logic
if preMktSession and not inPreMktSession
    // Session started
    inPreMktSession := true
    preMktOpen := open
    preMktHigh := high
    preMktLow := low
    preMktClose := close

if inPreMktSession and preMktSession
    // Update session data
    preMktHigh := math.max(preMktHigh, high)
    preMktLow := math.min(preMktLow, low)
    preMktClose := close

if inPreMktSession and not preMktSession
    // Session ended - store data
    inPreMktSession := false
    if not na(preMktHigh) and not na(preMktLow)
        preMktRange = preMktHigh - preMktLow
        preMktDirection = preMktClose > preMktOpen ? "Bull" : "Bear"
        
        // Store in arrays (keep only last X days)
        if array.size(dates) >= StatsLookback
            array.shift(dates)
            array.shift(preMktRanges)
            array.shift(preMktDirections)
        
        array.push(dates, str.format("{0,date,MM/dd}", time))
        array.push(preMktRanges, preMktRange)
        array.push(preMktDirections, preMktDirection)

// NY Session Logic
if nySession and not inNYSession
    // Session started
    inNYSession := true
    nyOpen := open
    nyHigh := high
    nyLow := low
    nyClose := close

if inNYSession and nySession
    // Update session data
    nyHigh := math.max(nyHigh, high)
    nyLow := math.min(nyLow, low)
    nyClose := close

if inNYSession and not nySession
    // Session ended - store data
    inNYSession := false
    if not na(nyHigh) and not na(nyLow)
        nyRange = nyHigh - nyLow
        nyDirection = nyClose > nyOpen ? "Bull" : "Bear"
        
        // Store in arrays (keep only last X days)
        if array.size(nyRanges) >= StatsLookback
            array.shift(nyRanges)
            array.shift(nyDirections)
        
        array.push(nyRanges, nyRange)
        array.push(nyDirections, nyDirection)

// Statistics Table
if ShowStatsTable and barstate.islast
    var table statsTable = table.new(position = TablePosition == "top_left" ? position.top_left : 
                                     TablePosition == "top_center" ? position.top_center :
                                     TablePosition == "top_right" ? position.top_right :
                                     TablePosition == "middle_left" ? position.middle_left :
                                     TablePosition == "middle_center" ? position.middle_center :
                                     TablePosition == "middle_right" ? position.middle_right :
                                     TablePosition == "bottom_left" ? position.bottom_left :
                                     TablePosition == "bottom_center" ? position.bottom_center :
                                     position.bottom_right, 
                                     columns = 3, rows = StatsLookback + 3, bgcolor = color.new(color.black, 80), border_width = 1)
    
    // Clear table
    table.clear(statsTable, 0, 0, 2, StatsLookback + 2)
    
    // Headers
    table.cell(statsTable, 0, 0, "Date", text_color = color.white, text_size = size.small, bgcolor = color.new(color.gray, 50))
    table.cell(statsTable, 1, 0, "PreMkt Pts", text_color = color.white, text_size = size.small, bgcolor = color.new(color.orange, 50))
    table.cell(statsTable, 2, 0, "NY Pts", text_color = color.white, text_size = size.small, bgcolor = color.new(color.green, 50))
    
    // Calculate averages
    var float preMktSum = 0.0
    var float nySum = 0.0
    var int dayCount = 0
    
    // Fill data rows and calculate sums
    for i = 0 to StatsLookback - 1
        if i < array.size(dates) // Changed from sessionsData to dates
            dateStr = array.get(dates, array.size(dates) - 1 - i) // Changed from sessionData to dates
            
            preMktRange = array.get(preMktRanges, array.size(preMktRanges) - 1 - i) // Changed from sessionData to preMktRanges
            nyRange = array.get(nyRanges, array.size(nyRanges) - 1 - i) // Changed from sessionData to nyRanges
            preMktDir = array.get(preMktDirections, array.size(preMktDirections) - 1 - i) // Changed from sessionData to preMktDirections
            nyDir = array.get(nyDirections, array.size(nyDirections) - 1 - i) // Changed from sessionData to nyDirections
            
            preMktColor = preMktDir == "Bull" ? color.new(color.green, 70) : color.new(color.red, 70)
            nyColor = nyDir == "Bull" ? color.new(color.green, 70) : color.new(color.red, 70)
            
            // dateStr = str.tostring(array.get(sessionData, 0), "MM/dd") // This line was removed as per new_code
            
            table.cell(statsTable, 0, i + 1, dateStr, text_color = color.black, text_size = size.normal, bgcolor = color.white)
            table.cell(statsTable, 1, i + 1, str.tostring(preMktRange, "#.#"), text_color = color.black, text_size = size.normal, bgcolor = preMktColor)
            table.cell(statsTable, 2, i + 1, str.tostring(nyRange, "#.#"), text_color = color.black, text_size = size.normal, bgcolor = nyColor)
            
            // Add to sums
            preMktSum += preMktRange
            nySum += nyRange
            dayCount += 1
    
    // Add totals row
    if dayCount > 0
        preMktAvg = preMktSum / dayCount
        nyAvg = nySum / dayCount
        
        table.cell(statsTable, 0, StatsLookback + 1, "Avg (" + str.tostring(dayCount) + "d)", text_color = color.white, text_size = size.small, bgcolor = color.new(color.blue, 20))
        table.cell(statsTable, 1, StatsLookback + 1, str.tostring(preMktAvg, "#.#"), text_color = color.white, text_size = size.small, bgcolor = color.new(color.blue, 20))
        table.cell(statsTable, 2, StatsLookback + 1, str.tostring(nyAvg, "#.#"), text_color = color.white, text_size = size.small, bgcolor = color.new(color.blue, 20))

// Call Sessions and KillZones Library
Sess.SessionDetector('PreMkt'  , PreMkt_SessTime, PreMkt_KillTime, show_PreMktSess, show_PreMktKill, 'Session', ShowMoreInfo, PreMkt_color, ColorMoreInfo)
Sess.SessionDetector('NY', NY_SessTime, NY_KillTime, show_NYSess, show_NYKill, 'Session', ShowMoreInfo, NY_color, ColorMoreInfo)