//@version=6
indicator("SZTrades Kernel Regression", "SZT Kernel", overlay = true)

// Import kernel functions - Note: You'll need to add this library manually in TradingView
// import jdehorty/KernelFunctions/2 as kernels

// Kernel Settings  
h = input.int(8, 'Lookback Window', minval=3, tooltip='The number of bars used for the estimation. This is a sliding value that represents the most recent historical bars. Recommended range: 3-50', group="Kernel Settings")
r = input.float(8., 'Relative Weighting', step=0.25, tooltip='Relative weighting of time frames. As this value approaches zero, the longer time frames will exert more influence on the estimation. As this value approaches infinity, the behavior of the Rational Quadratic Kernel will become identical to the Gaussian kernel. Recommended range: 0.25-25', group="Kernel Settings")
x = input.int(25, "Regression Level", tooltip='Bar index on which to start regression. Controls how tightly fit the kernel estimate is to the data. Smaller values are a tighter fit. Larger values are a looser fit. Recommended range: 2-25', group="Kernel Settings")
useKernelSmoothing = input.bool(false, "Enhance Kernel Smoothing", tooltip="Uses a crossover based mechanism to smoothen kernel color changes. This often results in less color transitions overall and may result in more ML entry signals being generated.", group='Kernel Settings')
lag = input.int(2, "Lag", tooltip="Lag for crossover detection. Lower values result in earlier crossovers. Recommended range: 1-2", group='Kernel Settings')

// Display Settings
useKernelFilter = input.bool(true, "Trade with Kernel", group="Kernel Settings")
showKernelEstimate = input.bool(true, "Show Kernel Estimate", group="Display Settings")
LineWidth = input.int(2, "Line Width", minval=1, maxval=5, group="Display Settings")

// Color Settings
BullishColor = input.color(#009988, "Bullish Color", group="Colors")
BearishColor = input.color(#CC3311, "Bearish Color", group="Colors")
Transparency = input.int(20, "Line Transparency", minval=0, maxval=100, group="Colors")

// Source
source = input.source(close, "Source", group="Kernel Settings")

// ====================================
// ==== Kernel Regression Logic ====
// ====================================

// Kernel Functions - Recreated to match original library behavior
// Rational Quadratic Kernel
rationalQuadratic(src, lookback, relativeWeight, startingBar) =>
    sumWeightedY = 0.0
    sumWeights = 0.0
    
    for i = 0 to lookback - 1
        y = src[i]
        distanceSquared = math.pow(i, 2)
        // Rational Quadratic formula: (1 + distance²/(2*α*ρ²))^(-α)
        alpha = relativeWeight
        rho = startingBar
        weight = math.pow(1 + distanceSquared / (2 * alpha * math.pow(rho, 2)), -alpha)
        
        sumWeightedY += y * weight
        sumWeights += weight
    
    result = sumWeights > 0 ? sumWeightedY / sumWeights : src
    result

// Gaussian Kernel  
gaussian(src, lookback, startingBar) =>
    sumWeightedY = 0.0
    sumWeights = 0.0
    
    for i = 0 to lookback - 1
        y = src[i]
        distanceSquared = math.pow(i, 2)
        // Gaussian formula: exp(-distance²/(2*σ²))
        sigma = startingBar
        weight = math.exp(-distanceSquared / (2 * math.pow(sigma, 2)))
        
        sumWeightedY += y * weight
        sumWeights += weight
    
    result = sumWeights > 0 ? sumWeightedY / sumWeights : src
    result

// Calculate Kernel Estimates
yhat1 = rationalQuadratic(source, h, r, x)
yhat2 = gaussian(source, h - lag, x)
kernelEstimate = yhat1

// Kernel Rate of Change Detection
wasBearishRate = yhat1[2] > yhat1[1]
wasBullishRate = yhat1[2] < yhat1[1]
isBearishRate = yhat1[1] > yhat1
isBullishRate = yhat1[1] < yhat1
isBearishChange = isBearishRate and wasBullishRate
isBullishChange = isBullishRate and wasBearishRate

// Kernel Crossovers
isBullishCrossAlert = ta.crossover(yhat2, yhat1)
isBearishCrossAlert = ta.crossunder(yhat2, yhat1) 
isBullishSmooth = yhat2 >= yhat1
isBearishSmooth = yhat2 <= yhat1

// Color Logic
bullishColorWithTransp = color.new(BullishColor, Transparency)
bearishColorWithTransp = color.new(BearishColor, Transparency)
colorByCross = isBullishSmooth ? bullishColorWithTransp : bearishColorWithTransp
colorByRate = isBullishRate ? bullishColorWithTransp : bearishColorWithTransp
plotColor = showKernelEstimate ? (useKernelSmoothing ? colorByCross : colorByRate) : na

// Plot Kernel Regression Line
plot(showKernelEstimate ? kernelEstimate : na, color=plotColor, linewidth=LineWidth, title="Kernel Regression")

// Background Color (optional)
ShowBackground = input.bool(false, "Show Background Color", group="Display Settings")
BgTransparency = input.int(95, "Background Transparency", minval=80, maxval=99, group="Display Settings")

bgcolor(ShowBackground ? (useKernelSmoothing ? (isBullishSmooth ? color.new(BullishColor, BgTransparency) : color.new(BearishColor, BgTransparency)) : (isBullishRate ? color.new(BullishColor, BgTransparency) : color.new(BearishColor, BgTransparency))) : na)

// Alert Conditions
alertBullish = useKernelSmoothing ? isBullishCrossAlert : isBullishChange
alertBearish = useKernelSmoothing ? isBearishCrossAlert : isBearishChange

alertcondition(alertBullish, title='Kernel Bullish Signal', message='Kernel Bullish ▲')
alertcondition(alertBearish, title='Kernel Bearish Signal', message='Kernel Bearish ▼')

// Table with Current Values (optional)
ShowTable = input.bool(false, "Show Info Table", group="Display Settings")
TablePosition = input.string("top_right", "Table Position", options=["top_left", "top_center", "top_right", "middle_left", "middle_center", "middle_right", "bottom_left", "bottom_center", "bottom_right"], group="Display Settings")

if ShowTable and barstate.islast
    var table infoTable = table.new(position = TablePosition == "top_left" ? position.top_left : 
                                   TablePosition == "top_center" ? position.top_center :
                                   TablePosition == "top_right" ? position.top_right :
                                   TablePosition == "middle_left" ? position.middle_left :
                                   TablePosition == "middle_center" ? position.middle_center :
                                   TablePosition == "middle_right" ? position.middle_right :
                                   TablePosition == "bottom_left" ? position.bottom_left :
                                   TablePosition == "bottom_center" ? position.bottom_center :
                                   position.bottom_right, 
                                   columns = 2, rows = 4, bgcolor = color.new(color.black, 80), border_width = 1)
    
    // Clear table
    table.clear(infoTable, 0, 0, 1, 3)
    
    // Table content
    table.cell(infoTable, 0, 0, "Metric", text_color = color.white, text_size = size.small, bgcolor = color.new(color.gray, 50))
    table.cell(infoTable, 1, 0, "Value", text_color = color.white, text_size = size.small, bgcolor = color.new(color.gray, 50))
    
    table.cell(infoTable, 0, 1, "Kernel Value", text_color = color.white, text_size = size.small)
    table.cell(infoTable, 1, 1, str.tostring(kernelEstimate, "#.##"), text_color = color.white, text_size = size.small)
    
    table.cell(infoTable, 0, 2, "Direction", text_color = color.white, text_size = size.small)
    direction_text = useKernelSmoothing ? (isBullishSmooth ? "Bullish" : "Bearish") : (isBullishRate ? "Bullish" : "Bearish")
    direction_color = useKernelSmoothing ? (isBullishSmooth ? color.green : color.red) : (isBullishRate ? color.green : color.red)
    table.cell(infoTable, 1, 2, direction_text, text_color = direction_color, text_size = size.small)
    
    table.cell(infoTable, 0, 3, "Mode", text_color = color.white, text_size = size.small)
    table.cell(infoTable, 1, 3, useKernelSmoothing ? "Smooth" : "Responsive", text_color = color.white, text_size = size.small)