//@version=6
indicator("SZT HTF CVD", shorttitle="SZT HTF", overlay=false, max_lines_count=500, max_labels_count=200)

// ─────────────────────────────────────────────
// Inputs
// ─────────────────────────────────────────────
htfRes = input.timeframe("5", "HTF", confirm=true)
emaLen = input.int(14, "Longitud EMA CVD", minval=1)
showBuy = input.bool(true, "Mostrar EMA compras")
showSell = input.bool(true, "Mostrar EMA ventas")
showCvd = input.bool(true, "Mostrar delta acumulado")
buyColor = input.color(color.new(color.teal, 0), "Color compras")
sellColor = input.color(color.new(color.red, 0), "Color ventas")
cvdPosColor = input.color(color.new(color.green, 0), "Color CVD +")
cvdNegColor = input.color(color.new(color.red, 0), "Color CVD -")
waveColor = input.color(color.new(color.gray, 70), "Color wave EMA")

// --- FUNCTION: run full CVD logic IN-HTF context (returns tuple)
f_cvd(emaLen) =>
    _o = open
    _h = high
    _l = low
    _c = close
    _v = volume
    ready = not na(_o) and not na(_h) and not na(_l) and not na(_c) and not na(_v) and (_h - _l) >= syminfo.mintick
    _spread = math.max(_h - _l, syminfo.mintick)
    _upper = _c > _o ? _h - _c : _h - _o
    _lower = _c > _o ? _o - _l : _c - _l
    _body = _spread - (_upper + _lower)
    _pctUpper = _upper / _spread
    _pctLower = _lower / _spread
    _pctBody = _body / _spread
    _halfW = (_pctUpper + _pctLower) * 0.5

    _buyVol = ready ? (_c > _o ? (_pctBody + _halfW) * _v : _halfW * _v) : na
    _sellVol = ready ? (_c < _o ? (_pctBody + _halfW) * _v : _halfW * _v) : na

    _buyEma = ta.ema(_buyVol, emaLen)
    _sellEma = ta.ema(_sellVol, emaLen)
    _cvd = ta.cum(nz(_buyVol) - nz(_sellVol))
    _wave = ta.ema(math.max(_buyEma, _sellEma), emaLen)

    [_buyEma, _sellEma, _cvd, _wave, time]

// --- Request HTF-calculated series with lookahead OFF for exact timing
[htfBuyEma, htfSellEma, htfCvd, htfWave, htfTime] = request.security(
    syminfo.tickerid,
    htfRes,
    f_cvd(emaLen),
    lookahead=barmerge.lookahead_off,
    gaps=barmerge.gaps_off
)

// --- Freeze on LTF: just use the HTF outputs (update occurs when HTF closes)
buySeries = htfBuyEma
sellSeries = htfSellEma
cvdSeries = htfCvd
waveSeries = htfWave

// Optional: detect first LTF bar after HTF close if needed
htfNewPoint = ta.change(htfTime) != 0

// Plots (same aesthetic)
pb = plot(showBuy ? buySeries : na, title="EMA Compras", color=buyColor, linewidth=2)
ps = plot(showSell ? sellSeries : na, title="EMA Ventas", color=sellColor, linewidth=2)
fill(pb, ps, color=buySeries > sellSeries ? color.new(color.green, 60) : buySeries < sellSeries ? color.new(color.red, 60) : color.new(color.yellow, 60))
plot(waveSeries, title="Wave EMA", color=waveColor, linewidth=2)
plot(showCvd ? cvdSeries : na, title="HTF CVD", style=plot.style_columns, color=cvdSeries >= 0 ? cvdPosColor : cvdNegColor, linewidth=2)
