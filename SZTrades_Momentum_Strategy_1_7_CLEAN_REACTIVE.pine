//@version=6
strategy("SZTrades v1.7 CLEAN REACTIVE", overlay=true, pyramiding=0,
     default_qty_type=strategy.percent_of_equity, default_qty_value=100,
     process_orders_on_close=true, calc_on_every_tick=false)

//────────────────────────────────────────────
// Inputs (mínimos reales)
//────────────────────────────────────────────
t3Len = input.int(4, "T3 Length")
factorT3 = input.float(0.7, "T3 Factor")

emaLen = input.int(50, "Trend EMA")

flowLen = input.int(16, "Flow Length")

atrLen = input.int(14, "ATR Length")
atrMaLen = input.int(20, "ATR MA Length")
atrMinActive = input.float(2.5, "ATR Min Active")
atrHotThreshold = input.float(8.0, "ATR Hot Market")

regimeSlopeBars = input.int(5, "Regime Slope Bars")
regimeStrengthMin = input.float(0.8, "Regime Strength Min")

stopPoints = input.float(4.0, "Stop")
tpMult = input.float(2.0, "TP Mult")

cooldownBars = input.int(4, "Cooldown")

tradeSession = input.session("0800-0900", "Session")
tz = input.string("Etc/GMT+4", "Timezone")
warmupBarsInSession = input.int(2, "Session Warmup Bars")
maxRangeToAtr = input.float(2.2, "Max Range/ATR")

//────────────────────────────────────────────
// Core T3
//────────────────────────────────────────────
t3(src, len) => ta.ema(src, len) * (1 + factorT3) - ta.ema(ta.ema(src, len), len) * factorT3

t3v = t3(t3(t3(close, t3Len), t3Len), t3Len)
t3Up = t3v > t3v[1]
t3Dn = t3v < t3v[1]

//────────────────────────────────────────────
// Trend
//────────────────────────────────────────────
ema = ta.ema(close, emaLen)
trendLong = close > ema
trendShort = close < ema
emaSlope = ema - ema[regimeSlopeBars]

//────────────────────────────────────────────
// Flow proxy (rango + cierre relativo + volumen)
//────────────────────────────────────────────
spread = math.max(high - low, syminfo.mintick)
closePos = ((close - low) / spread) * 2.0 - 1.0
bodyRatio = math.min(math.abs(close - open) / spread, 1.0)
flowDelta = volume * closePos * (0.5 + bodyRatio * 0.5)
flow = ta.ema(flowDelta, flowLen)
bullFlow = flow > 0
bearFlow = flow < 0

//────────────────────────────────────────────
// Volatility hard gate + regime mínimo
//────────────────────────────────────────────
atr = ta.atr(atrLen)
atrMA = ta.sma(atr, atrMaLen)
atrActive = atr >= atrMinActive
hotMarket = atr >= atrHotThreshold
volOk = atrActive and (hotMarket or atr > atrMA)

trendStrength = math.abs(emaSlope) / math.max(atr, syminfo.mintick)
regimeDirectional = trendStrength >= regimeStrengthMin and ((trendLong and emaSlope > 0) or (trendShort and emaSlope < 0))
regimeOk = hotMarket or regimeDirectional

//────────────────────────────────────────────
// Session + micro-ruido control
//────────────────────────────────────────────
inSession = not na(time(timeframe.period, tradeSession, tz))
sessionStart = inSession and not inSession[1]
var int sessionBars = 0
if sessionStart
    sessionBars := 1
else if inSession
    sessionBars += 1
else
    sessionBars := 0

sessionWarmOk = sessionBars > warmupBarsInSession
rangeNoiseOk = atr > 0 and spread <= atr * maxRangeToAtr
sessionQualityOk = inSession and sessionWarmOk and rangeNoiseOk

//────────────────────────────────────────────
// Cooldown
//────────────────────────────────────────────
var int lastTrade = na
cooldownOk = na(lastTrade) or (bar_index - lastTrade > cooldownBars)

//────────────────────────────────────────────
// Signals (minimal reactivo)
// trend + flow + volatility + regime
//────────────────────────────────────────────
longSignal =
     sessionQualityOk and
     cooldownOk and
     t3Up and
     trendLong and
     bullFlow and
     volOk and
     regimeOk and
     barstate.isconfirmed

shortSignal =
     sessionQualityOk and
     cooldownOk and
     t3Dn and
     trendShort and
     bearFlow and
     volOk and
     regimeOk and
     barstate.isconfirmed

//────────────────────────────────────────────
// Entries
//────────────────────────────────────────────
if longSignal and strategy.position_size == 0
    strategy.entry("L", strategy.long)
    lastTrade := bar_index

if shortSignal and strategy.position_size == 0
    strategy.entry("S", strategy.short)
    lastTrade := bar_index

//────────────────────────────────────────────
// Risk (modular for future structural stop)
//────────────────────────────────────────────
longStop = strategy.position_avg_price - stopPoints
longTP   = strategy.position_avg_price + stopPoints * tpMult

shortStop = strategy.position_avg_price + stopPoints
shortTP   = strategy.position_avg_price - stopPoints * tpMult

strategy.exit("LX", "L", stop=longStop, limit=longTP)
strategy.exit("SX", "S", stop=shortStop, limit=shortTP)

//────────────────────────────────────────────
// Visual
//────────────────────────────────────────────
plot(t3v, color=color.orange)
plot(ema, color=color.aqua)
