//@version=6
indicator('SZTrades Jurik Volatility Bands', shorttitle='SZT JVB', overlay=false)

// Settings (preserve original behavior; add smoothing mode)
useJurik      = input.bool(true, title='use Jurik?')
inverseJurik  = input.bool(false, title='Inverse Jurik?')
lengthJurik   = input.int(14, minval=1, title='length - Jurik')
smoothJurik   = input.int(2,  minval=1, title='smooth - Jurik')
colorPriceJurik = input.color(color.aqua, title='Color - Jurik')
// New: configurable smoothing source
smoothingMode = input.string('wma', 'Smoothing Mode', options=['ema','wma','swma','vwma','hull','tema'])

// Helper MAs (for smoothing mode)
tema(src, len) =>
    ema1 = ta.ema(src, len)
    ema2 = ta.ema(ema1, len)
    ema3 = ta.ema(ema2, len)
    3 * ema1 - 3 * ema2 + ema3

maGeneric(mode, src, len) =>
    if mode == 'ema'
        ta.ema(src, len)
    else if mode == 'wma'
        ta.wma(src, len)
    else if mode == 'swma'
        ta.swma(src)
    else if mode == 'vwma'
        ta.vwma(src, len)
    else if mode == 'hull'
        ta.wma(2 * ta.wma(src, math.max(1, len / 2)) - ta.wma(src, len), math.max(1, math.round(math.sqrt(len))))
    else if mode == 'tema'
        tema(src, len)
    else
        ta.wma(src, len)

// --- original logic ---
vpriceJurik = float(na)
cpriceJurik = float(na)
vpriceJurik := ta.sma(close, 1)
cpriceJurik := ta.sma(close, 1)

hpriceJurik = ta.highest(vpriceJurik, lengthJurik)
lpriceJurik = ta.lowest(vpriceJurik, lengthJurik)

bsJurikmax = float(na)
bsJurikmin = float(na)
bsJurikmax := na(bsJurikmax[1]) ? nz(na) : nz(bsJurikmax[1])
bsJurikmin := na(bsJurikmin[1]) ? nz(na) : nz(bsJurikmin[1])

delJurik1 = hpriceJurik - nz(bsJurikmax[1])
delJurik2 = lpriceJurik - nz(bsJurikmin[1])

lenJurik = math.sqrt(0.5 * (lengthJurik - 1)) * 1
k = math.exp(math.sqrt(1) * math.log(lenJurik / (lenJurik + 1)))

if delJurik1 > 0
    bsJurikmax := hpriceJurik
else
    bsJurikmax := hpriceJurik - k * delJurik1

if delJurik2 < 0
    bsJurikmin := lpriceJurik
else
    bsJurikmin := lpriceJurik - k * delJurik2

// Bands and centered price (original)
dnValueJurik = bsJurikmin
upValueJurik = bsJurikmax
miValueJurik = (upValueJurik + dnValueJurik) / 2.0

// Apply configurable smoothing in place of fixed WMA
len2 = smoothJurik <= 1 ? smoothJurik : smoothJurik / 2
len2i = math.max(1, math.round(len2))
upValueJuriks = maGeneric(smoothingMode, (upValueJurik - miValueJurik), len2i)
dnValueJuriks = maGeneric(smoothingMode, (dnValueJurik - miValueJurik), len2i)
priceJurik    = maGeneric(smoothingMode, (cpriceJurik - miValueJurik), smoothJurik)

signalLongJurik  = useJurik ? priceJurik > 0 : true
signalShortJurik = useJurik ? priceJurik < 0 : true

signalLongJurikFinal  = inverseJurik ? signalShortJurik : signalLongJurik
signalShortJurikFinal = inverseJurik ? signalLongJurik : signalShortJurik

plot(signalLongJurikFinal  ? 1 : 0, 'Heartbeat Long',  display=display.data_window)
plot(signalShortJurikFinal ? -1: 0, 'Heartbeat Short', display=display.data_window)

plot(upValueJuriks, title='Upper Band', color=color.green)
plot(dnValueJuriks, title='Lower Band', color=color.red)
plot(priceJurik,    title='Price',      color=(colorPriceJurik))
hline(0)