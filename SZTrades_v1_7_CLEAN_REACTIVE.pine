//@version=6
strategy("SZTrades v1.7 CLEAN REACTIVE", overlay=true, pyramiding=0,
     default_qty_type=strategy.percent_of_equity, default_qty_value=100,
     process_orders_on_close=true, calc_on_every_tick=false)

//────────────────────────────────────────────
// Inputs (minimal + reactive)
//────────────────────────────────────────────
t3Len = input.int(4, "T3 Length")
factorT3 = input.float(0.7, "T3 Factor")

emaLen = input.int(50, "Trend EMA")
regimeSlopeBars = input.int(5, "Regime Slope Bars", minval=1)
regimeMinStrength = input.float(0.20, "Regime Min Strength", minval=0.05, step=0.05)

cvdLen = input.int(16, "Flow Length")

atrLen = input.int(14, "ATR Length")
atrMaLen = input.int(20, "ATR MA Length")
atrMin = input.float(1.5, "ATR Min Gate", minval=0.1, step=0.1)
atrHot = input.float(8.0, "ATR Hot Mode", minval=0.5, step=0.5)
rangeMaLen = input.int(20, "Range MA Length", minval=2)
rangeExpansionMin = input.float(0.90, "Range Expansion Min", minval=0.5, step=0.05)

stopPoints = input.float(4.0, "Stop")
tpMult = input.float(2.0, "TP Mult")

cooldownBars = input.int(4, "Cooldown")

tradeSession = input.session("0800-0900", "Session")
tz = input.string("Etc/GMT+4", "Timezone")
sessionWarmupBars = input.int(2, "Session Warmup Bars", minval=0)
earlyRangeAnomalyMult = input.float(1.8, "Early Range Anomaly Mult", minval=1.0, step=0.1)

//────────────────────────────────────────────
// Core T3
//────────────────────────────────────────────
t3(src, len) => ta.ema(src, len) * (1 + factorT3) - ta.ema(ta.ema(src, len), len) * factorT3

t3v = t3(t3(t3(close, t3Len), t3Len), t3Len)
t3Up = t3v > t3v[1]
t3Dn = t3v < t3v[1]

//────────────────────────────────────────────
// Trend
//────────────────────────────────────────────
ema = ta.ema(close, emaLen)
trendLong = close > ema
trendShort = close < ema
emaSlope = ema - ema[regimeSlopeBars]

//────────────────────────────────────────────
// Flow proxy (directional pressure only)
//────────────────────────────────────────────
barRange = math.max(high - low, syminfo.mintick)
closePos = (close - open) / math.max(high - low, syminfo.mintick)
deltaProxy = closePos * volume
flow = ta.ema(deltaProxy, cvdLen)
bullFlow = flow > 0
bearFlow = flow < 0

//────────────────────────────────────────────
// Volatility hard gate + regime minimum
//────────────────────────────────────────────
atr = ta.atr(atrLen)
atrMA = ta.sma(atr, atrMaLen)
rangeMA = ta.sma(barRange, rangeMaLen)
rangeExpansionMult = math.max(rangeExpansionMin, 1.10)
rangeExpansionOk = not na(rangeMA) and barRange > rangeMA and math.abs(emaSlope) > 0

volHardOk = atr >= atrMin
highVolMode = atr >= atrHot
volOk = volHardOk and (highVolMode or atr > atrMA)

regimeStrength = atr > 0 ? math.abs(emaSlope) / atr : 0.0
regimeStrengthOk = regimeStrength >= regimeMinStrength and rangeExpansionOk
regimeLongOk = highVolMode or (trendLong and emaSlope > 0 and regimeStrengthOk)
regimeShortOk = highVolMode or (trendShort and emaSlope < 0 and regimeStrengthOk)

//────────────────────────────────────────────
// Session + micro-noise control
//────────────────────────────────────────────
inSession = not na(time(timeframe.period, tradeSession, tz))
sessionStarted = inSession and not inSession[1]

var int sessionBars = 0
if sessionStarted
    sessionBars := 1
else if inSession
    sessionBars += 1
else
    sessionBars := 0

earlySession = inSession and sessionBars <= sessionWarmupBars + 2
anomalousEarlyRange = earlySession and not na(rangeMA) and barRange > rangeMA * earlyRangeAnomalyMult
sessionNoiseOk = inSession and sessionBars > sessionWarmupBars and not anomalousEarlyRange

//────────────────────────────────────────────
// Cooldown
//────────────────────────────────────────────
var int lastTrade = na
cooldownOk = na(lastTrade) or (bar_index - lastTrade > cooldownBars)

//────────────────────────────────────────────
// Signals (minimal reactive stack)
//────────────────────────────────────────────
longSignal =
     sessionNoiseOk and
     cooldownOk and
     t3Up and
     trendLong and
     bullFlow and
     volOk and
     regimeLongOk and
     barstate.isconfirmed

shortSignal =
     sessionNoiseOk and
     cooldownOk and
     t3Dn and
     trendShort and
     bearFlow and
     volOk and
     regimeShortOk and
     barstate.isconfirmed

//────────────────────────────────────────────
// Entries
//────────────────────────────────────────────
if longSignal and strategy.position_size == 0
    strategy.entry("L", strategy.long)
    lastTrade := bar_index

if shortSignal and strategy.position_size == 0
    strategy.entry("S", strategy.short)
    lastTrade := bar_index

//────────────────────────────────────────────
// Risk (modular for future structural SL)
//────────────────────────────────────────────
longStopBase = strategy.position_avg_price - stopPoints
longTPBase = strategy.position_avg_price + stopPoints * tpMult
shortStopBase = strategy.position_avg_price + stopPoints
shortTPBase = strategy.position_avg_price - stopPoints * tpMult

// Placeholder hook for future structural stop switch.
longStop = longStopBase
longTP = longTPBase
shortStop = shortStopBase
shortTP = shortTPBase

strategy.exit("LX", "L", stop=longStop, limit=longTP)
strategy.exit("SX", "S", stop=shortStop, limit=shortTP)

//────────────────────────────────────────────
// Visual
//────────────────────────────────────────────
plot(t3v, color=color.orange)
plot(ema, color=color.aqua)
