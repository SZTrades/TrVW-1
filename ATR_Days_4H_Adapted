//@version=6
indicator("ATR Momentum Oscillator - 4H Adapted", "ATR Momentum", overlay=false)

// === INPUTS (Adapted for 4H) ===
lookbackPeriods = input.int(title="Lookback Periods", defval=12, minval=3, maxval=24, tooltip="4H bars to look back (12 = 2 days)")
src = input(close, title="Source")
atrLength = input.int(title="ATR Length", defval=14, minval=5, maxval=50, tooltip="ATR calculation period")
upperThreshold = input.float(title="Upper Threshold", defval=3.0, minval=1.0, maxval=6.0, step=0.5, tooltip="Extreme bullish momentum level")
lowerThreshold = input.float(title="Lower Threshold", defval=-3.0, minval=-6.0, maxval=-1.0, step=0.5, tooltip="Extreme bearish momentum level")

// Bollinger Bands Settings
bbLength = input.int(title="Bollinger Length", defval=20, minval=10, maxval=50)
bbMult = input.float(title="Bollinger Multiplier", defval=2.0, minval=1.0, maxval=3.0, step=0.1)

// === MOVE CALCULATION ===
move = 0.0
for i = 0 to lookbackPeriods
    distHigh = low - high[i]
    distLow  = high - low[i]
    maxDist  = math.max(math.abs(distHigh), math.abs(distLow))
    if maxDist > math.abs(move)
        move := maxDist
        // Flip the sign if the bigger distance is negative
        if math.abs(distHigh) > math.abs(distLow) and distHigh < 0
            move := move * -1
        if math.abs(distLow) > math.abs(distHigh) and distLow < 0
            move := move * -1

// === ATR CALCULATION (Responsive for 4H) ===
curAtr = ta.rma(ta.tr(true)[1], atrLength)
move := move / curAtr

// === BOLLINGER BAND CALCULATION ===
basis = ta.sma(src, bbLength)
dev = bbMult * ta.stdev(src, bbLength)
upperBollinger = basis + dev
lowerBollinger = basis - dev

// === MAIN PLOT (BLUE OSCILLATOR) ===
plotMove = plot(move, color=color.blue, title="ATR Momentum", linewidth=2)

// === SIGNAL DOTS (4H Adapted) ===
// Bullish exhaustion: Extreme positive + price above upper BB
// Bearish exhaustion: Extreme negative + price below lower BB
bullishSignal = (move >= upperThreshold and open > upperBollinger) ? move : na
bearishSignal = (move <= lowerThreshold and open < lowerBollinger) ? move : na

plot(bullishSignal, title="Bullish Exhaustion", style=plot.style_circles, color=color.red, linewidth=4)
plot(bearishSignal, title="Bearish Exhaustion", style=plot.style_circles, color=color.lime, linewidth=4)

// === HORIZONTAL THRESHOLDS ===
hline(upperThreshold, title="Upper Threshold", color=color.gray, linewidth=1, linestyle=hline.style_dashed)
hline(lowerThreshold, title="Lower Threshold", color=color.gray, linewidth=1, linestyle=hline.style_dashed)
hline(0, title="Zero Line", color=color.yellow, linewidth=1)

// === MOMENTUM ZONES (FILL) ===
overPlot = plot(move >= upperThreshold ? move : na, color=color.new(color.blue, 0), linewidth=2, display=display.none)
underPlot = plot(move <= lowerThreshold ? move : na, color=color.new(color.blue, 0), linewidth=2, display=display.none)

plotUpperLine = plot(upperThreshold, title="Upper Fill Line", color=color.new(color.white, 0), display=display.none)
plotLowerLine = plot(lowerThreshold, title="Lower Fill Line", color=color.new(color.white, 0), display=display.none)

// Extreme momentum zones
fill(overPlot, plotUpperLine, color=color.new(color.orange, 85), title="Extreme Bullish Zone")
fill(underPlot, plotLowerLine, color=color.new(color.purple, 85), title="Extreme Bearish Zone")

// === DIVERGENCE ZONES (Additional) ===
// Light background when oscillator is in extreme territory
bgcolor(move >= upperThreshold ? color.new(color.red, 95) : move <= lowerThreshold ? color.new(color.green, 95) : na, title="Extreme Momentum Background")

// === INFO TABLE (4H Optimized) ===
var infoTable = table.new(position=position.top_right, columns=2, rows=3, bgcolor=color.new(color.black, 20), 
                          border_color=color.white, border_width=1, frame_width=1)

if barstate.islast
    table.clear(infoTable, 0, 0, 1, 2)
    
    // Current ATR
    table.cell(infoTable, 0, 0, text="ATR", bgcolor=color.blue, text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 0, text=str.tostring(math.round(curAtr * 100) / 100), bgcolor=color.black, text_color=color.white, text_size=size.small)
    
    // Current Momentum
    table.cell(infoTable, 0, 1, text="Momentum", bgcolor=color.gray, text_color=color.white, text_size=size.small)
    momentumColor = move > 0 ? color.green : color.red
    table.cell(infoTable, 1, 1, text=str.tostring(math.round(move * 100) / 100), bgcolor=momentumColor, text_color=color.white, text_size=size.small)
    
    // Status
    status = move >= upperThreshold ? "EXTREME ↑" : move <= lowerThreshold ? "EXTREME ↓" : "NORMAL"
    statusColor = move >= upperThreshold ? color.red : move <= lowerThreshold ? color.lime : color.gray
    table.cell(infoTable, 0, 2, text="Status", bgcolor=color.gray, text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 2, text=status, bgcolor=statusColor, text_color=color.black, text_size=size.small)