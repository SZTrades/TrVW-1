//@version=6
indicator("ATR Momentum Oscillator - 4H Adapted", "ATR Momentum", overlay=false)

// === ASSET PRESETS ===
presetAsset = input.string(title="Asset Preset", defval="Gold", options=["Gold", "Silver", "DXY", "Custom"], group="Asset Settings", tooltip="Pre-configured settings for different assets")

// === CORE SETTINGS ===
lookbackPeriods = input.int(title="Lookback Periods", defval=12, minval=3, maxval=48, step=1, group="Core Settings", tooltip="4H bars to look back (12 = 2 days, 24 = 4 days)")
src = input(close, title="Source", group="Core Settings")
atrLength = input.int(title="ATR Length", defval=14, minval=5, maxval=50, step=1, group="Core Settings", tooltip="ATR calculation period")

// === THRESHOLD SETTINGS ===
upperThreshold = input.float(title="Upper Threshold", defval=3.0, minval=1.0, maxval=8.0, step=0.1, group="Thresholds", tooltip="Extreme bullish momentum level")
lowerThreshold = input.float(title="Lower Threshold", defval=-3.0, minval=-8.0, maxval=-1.0, step=0.1, group="Thresholds", tooltip="Extreme bearish momentum level")

// === BOLLINGER BANDS SETTINGS ===
bbLength = input.int(title="Bollinger Length", defval=20, minval=10, maxval=50, step=1, group="Bollinger Bands")
bbMult = input.float(title="Bollinger Multiplier", defval=2.0, minval=1.0, maxval=3.0, step=0.1, group="Bollinger Bands")

// === ASSET-SPECIFIC ADJUSTMENTS ===
// Auto-adjust settings based on preset (user can still override)
adjustedLookback = switch presetAsset
    "Gold" => 12      // 2 days - responsive for trending moves
    "Silver" => 8     // 1.5 days - more volatile, shorter lookback  
    "DXY" => 18       // 3 days - slower moving, longer lookback
    "Custom" => lookbackPeriods
    => lookbackPeriods

adjustedUpperThreshold = switch presetAsset
    "Gold" => 3.0     // Standard momentum threshold
    "Silver" => 2.5   // Lower threshold - more volatile
    "DXY" => 4.0      // Higher threshold - less volatile
    "Custom" => upperThreshold
    => upperThreshold

adjustedLowerThreshold = switch presetAsset
    "Gold" => -3.0
    "Silver" => -2.5
    "DXY" => -4.0
    "Custom" => lowerThreshold
    => lowerThreshold

adjustedATRLength = switch presetAsset
    "Gold" => 14      // Standard ATR
    "Silver" => 10    // Shorter for more responsiveness
    "DXY" => 20       // Longer for smoother calculation
    "Custom" => atrLength
    => atrLength

// Use adjusted values if not Custom
finalLookback = presetAsset == "Custom" ? lookbackPeriods : adjustedLookback
finalUpperThreshold = presetAsset == "Custom" ? upperThreshold : adjustedUpperThreshold
finalLowerThreshold = presetAsset == "Custom" ? lowerThreshold : adjustedLowerThreshold
finalATRLength = presetAsset == "Custom" ? atrLength : adjustedATRLength

// === MOVE CALCULATION ===
move = 0.0
for i = 0 to finalLookback
    distHigh = low - high[i]
    distLow  = high - low[i]
    maxDist  = math.max(math.abs(distHigh), math.abs(distLow))
    if maxDist > math.abs(move)
        move := maxDist
        // Flip the sign if the bigger distance is negative
        if math.abs(distHigh) > math.abs(distLow) and distHigh < 0
            move := move * -1
        if math.abs(distLow) > math.abs(distHigh) and distLow < 0
            move := move * -1

// === ATR CALCULATION (Responsive for 4H) ===
curAtr = ta.rma(ta.tr(true)[1], finalATRLength)
move := move / curAtr

// === BOLLINGER BAND CALCULATION ===
basis = ta.sma(src, bbLength)
dev = bbMult * ta.stdev(src, bbLength)
upperBollinger = basis + dev
lowerBollinger = basis - dev

// === MAIN PLOT (BLUE OSCILLATOR) ===
plotMove = plot(move, color=color.blue, title="ATR Momentum", linewidth=2)

// === SIGNAL DOTS (4H Adapted) ===
// Bullish exhaustion: Extreme positive + price above upper BB
// Bearish exhaustion: Extreme negative + price below lower BB
bullishSignal = (move >= finalUpperThreshold and open > upperBollinger) ? move : na
bearishSignal = (move <= finalLowerThreshold and open < lowerBollinger) ? move : na

plot(bullishSignal, title="Bullish Exhaustion", style=plot.style_circles, color=color.red, linewidth=4)
plot(bearishSignal, title="Bearish Exhaustion", style=plot.style_circles, color=color.lime, linewidth=4)

// === HORIZONTAL THRESHOLDS ===
hline(finalUpperThreshold, title="Upper Threshold", color=color.gray, linewidth=1, linestyle=hline.style_dashed)
hline(finalLowerThreshold, title="Lower Threshold", color=color.gray, linewidth=1, linestyle=hline.style_dashed)
hline(0, title="Zero Line", color=color.yellow, linewidth=1)

// === MOMENTUM ZONES (FILL) ===
overPlot = plot(move >= finalUpperThreshold ? move : na, color=color.new(color.blue, 0), linewidth=2, display=display.none)
underPlot = plot(move <= finalLowerThreshold ? move : na, color=color.new(color.blue, 0), linewidth=2, display=display.none)

plotUpperLine = plot(finalUpperThreshold, title="Upper Fill Line", color=color.new(color.white, 0), display=display.none)
plotLowerLine = plot(finalLowerThreshold, title="Lower Fill Line", color=color.new(color.white, 0), display=display.none)

// Extreme momentum zones
fill(overPlot, plotUpperLine, color=color.new(color.orange, 85), title="Extreme Bullish Zone")
fill(underPlot, plotLowerLine, color=color.new(color.purple, 85), title="Extreme Bearish Zone")

// === DIVERGENCE ZONES (Additional) ===
// Light background when oscillator is in extreme territory
bgcolor(move >= finalUpperThreshold ? color.new(color.red, 95) : move <= finalLowerThreshold ? color.new(color.green, 95) : na, title="Extreme Momentum Background")

// === INFO TABLE (4H Optimized) ===
var infoTable = table.new(position=position.top_right, columns=2, rows=3, bgcolor=color.new(color.black, 20), 
                          border_color=color.white, border_width=1, frame_width=1)

if barstate.islast
    table.clear(infoTable, 0, 0, 1, 2)
    
    // Current ATR
    table.cell(infoTable, 0, 0, text="ATR", bgcolor=color.blue, text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 0, text=str.tostring(math.round(curAtr * 100) / 100), bgcolor=color.black, text_color=color.white, text_size=size.small)
    
    // Current Momentum
    table.cell(infoTable, 0, 1, text="Momentum", bgcolor=color.gray, text_color=color.white, text_size=size.small)
    momentumColor = move > 0 ? color.green : color.red
    table.cell(infoTable, 1, 1, text=str.tostring(math.round(move * 100) / 100), bgcolor=momentumColor, text_color=color.white, text_size=size.small)
    
    // Status
    status = move >= finalUpperThreshold ? "EXTREME ↑" : move <= finalLowerThreshold ? "EXTREME ↓" : "NORMAL"
    statusColor = move >= finalUpperThreshold ? color.red : move <= finalLowerThreshold ? color.lime : color.gray
    table.cell(infoTable, 0, 2, text="Status", bgcolor=color.gray, text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 2, text=status, bgcolor=statusColor, text_color=color.black, text_size=size.small)