//@version=6
indicator("Liquidity Sonar", "Sonar", overlay=true)

// ====================================
// ==== Settings ====
// ====================================

// Level Display Settings
showWeeklyLevels = input.bool(true, "Show Weekly H/L", group="Levels")
showDailyLevels = input.bool(true, "Show Daily H/L", group="Levels")
showPrevDayLevels = input.bool(true, "Show Previous Day H/L", group="Levels")
maxWeeklyLevels = input.int(5, "Max Weekly Levels", minval=1, maxval=10, group="Levels", tooltip="Limit weekly H/L rays to avoid chart clutter")
maxDailyLevels = input.int(5, "Max Daily Levels", minval=1, maxval=10, group="Levels", tooltip="Limit daily H/L rays to avoid chart clutter")

// Ray Settings
rayLength = input.int(50, "Ray Length (bars)", minval=10, maxval=200, group="Display")
showTable = input.bool(true, "Show Distance Table", group="Display")
tablePosition = input.string("top_right", "Table Position", options=["top_left", "top_center", "top_right", "middle_left", "middle_center", "middle_right", "bottom_left", "bottom_center", "bottom_right"], group="Display")

// Ray Style Settings
weeklyColor = input.color(color.green, "Weekly Levels Color", group="Ray Styles")
dailyColor = input.color(color.blue, "Daily Levels Color", group="Ray Styles")
prevDayColor = input.color(color.orange, "Previous Day Color", group="Ray Styles")

rayTransparency = input.int(30, "Ray Transparency", minval=0, maxval=80, step=10, group="Ray Styles")
weeklyWidth = input.int(2, "Weekly Line Width", minval=1, maxval=4, group="Ray Styles")
dailyWidth = input.int(2, "Daily Line Width", minval=1, maxval=4, group="Ray Styles")
prevDayWidth = input.int(1, "Previous Day Width", minval=1, maxval=3, group="Ray Styles")

// ====================================
// ==== Level Calculations ====
// ====================================

// Weekly levels (true HTF data)
weeklyHigh = request.security(syminfo.tickerid, "1W", high, lookahead=barmerge.lookahead_off)
weeklyLow = request.security(syminfo.tickerid, "1W", low, lookahead=barmerge.lookahead_off)
prevWeeklyHigh = request.security(syminfo.tickerid, "1W", high[1], lookahead=barmerge.lookahead_off)
prevWeeklyLow = request.security(syminfo.tickerid, "1W", low[1], lookahead=barmerge.lookahead_off)

// Daily levels (current and previous)
dailyHigh = request.security(syminfo.tickerid, "1D", high, lookahead=barmerge.lookahead_off)
dailyLow = request.security(syminfo.tickerid, "1D", low, lookahead=barmerge.lookahead_off)
prevDailyHigh = request.security(syminfo.tickerid, "1D", high[1], lookahead=barmerge.lookahead_off)
prevDailyLow = request.security(syminfo.tickerid, "1D", low[1], lookahead=barmerge.lookahead_off)

// Historical level arrays (limited to max settings)
var array<float> weeklyHighs = array.new<float>()
var array<float> weeklyLows = array.new<float>()
var array<float> dailyHighs = array.new<float>()
var array<float> dailyLows = array.new<float>()

// Track new levels and limit arrays
newWeek = ta.change(time("1W")) != 0
newDay = ta.change(time("1D")) != 0

// Add new weekly levels
if newWeek
    array.unshift(weeklyHighs, weeklyHigh)
    array.unshift(weeklyLows, weeklyLow)
    // Keep only max levels
    if array.size(weeklyHighs) > maxWeeklyLevels
        array.pop(weeklyHighs)
    if array.size(weeklyLows) > maxWeeklyLevels
        array.pop(weeklyLows)

// Add new daily levels  
if newDay
    array.unshift(dailyHighs, dailyHigh)
    array.unshift(dailyLows, dailyLow)
    // Keep only max levels
    if array.size(dailyHighs) > maxDailyLevels
        array.pop(dailyHighs)
    if array.size(dailyLows) > maxDailyLevels
        array.pop(dailyLows)

// ====================================
// ==== Distance Calculations ====
// ====================================

// Current price reference
currentPrice = close

// Distance to weekly levels
distToWeeklyHigh = weeklyHigh - currentPrice
distToWeeklyLow = currentPrice - weeklyLow
distToPrevWeeklyHigh = prevWeeklyHigh - currentPrice
distToPrevWeeklyLow = currentPrice - prevWeeklyLow

// Distance to daily levels
distToDailyHigh = dailyHigh - currentPrice
distToDailyLow = currentPrice - dailyLow
distToPrevDailyHigh = prevDailyHigh - currentPrice
distToPrevDailyLow = currentPrice - prevDailyLow



// ====================================
// ==== Level Rays (Horizontal Lines) ====
// ====================================

// Weekly levels (limited)
if showWeeklyLevels and barstate.islast
    // Current week
    line.new(bar_index, weeklyHigh, bar_index + rayLength, weeklyHigh, extend=extend.none, color=color.new(weeklyColor, rayTransparency), width=weeklyWidth, style=line.style_solid)
    line.new(bar_index, weeklyLow, bar_index + rayLength, weeklyLow, extend=extend.none, color=color.new(weeklyColor, rayTransparency), width=weeklyWidth, style=line.style_solid)
    
    // Historical weekly levels
    for i = 0 to math.min(array.size(weeklyHighs) - 1, maxWeeklyLevels - 1)
        if i < array.size(weeklyHighs)
            line.new(bar_index, array.get(weeklyHighs, i), bar_index + rayLength, array.get(weeklyHighs, i), extend=extend.none, color=color.new(weeklyColor, rayTransparency + 20), width=1, style=line.style_dashed)
        if i < array.size(weeklyLows)
            line.new(bar_index, array.get(weeklyLows, i), bar_index + rayLength, array.get(weeklyLows, i), extend=extend.none, color=color.new(weeklyColor, rayTransparency + 20), width=1, style=line.style_dashed)

// Daily levels (limited)
if showDailyLevels and barstate.islast
    // Current day
    line.new(bar_index, dailyHigh, bar_index + rayLength, dailyHigh, extend=extend.none, color=color.new(dailyColor, rayTransparency), width=dailyWidth, style=line.style_solid)
    line.new(bar_index, dailyLow, bar_index + rayLength, dailyLow, extend=extend.none, color=color.new(dailyColor, rayTransparency), width=dailyWidth, style=line.style_solid)
    
    // Historical daily levels
    for i = 0 to math.min(array.size(dailyHighs) - 1, maxDailyLevels - 1)
        if i < array.size(dailyHighs)
            line.new(bar_index, array.get(dailyHighs, i), bar_index + rayLength, array.get(dailyHighs, i), extend=extend.none, color=color.new(dailyColor, rayTransparency + 30), width=1, style=line.style_dotted)
        if i < array.size(dailyLows)
            line.new(bar_index, array.get(dailyLows, i), bar_index + rayLength, array.get(dailyLows, i), extend=extend.none, color=color.new(dailyColor, rayTransparency + 30), width=1, style=line.style_dotted)

// Previous daily levels
if showPrevDayLevels and barstate.islast
    line.new(bar_index, prevDailyHigh, bar_index + rayLength, prevDailyHigh, extend=extend.none, color=color.new(prevDayColor, rayTransparency + 20), width=prevDayWidth, style=line.style_dashed)
    line.new(bar_index, prevDailyLow, bar_index + rayLength, prevDailyLow, extend=extend.none, color=color.new(prevDayColor, rayTransparency + 20), width=prevDayWidth, style=line.style_dashed)

// ====================================
// ==== Clean Distance Table ====
// ====================================

if showTable and barstate.islast
    tablePos = tablePosition == "top_left" ? position.top_left : tablePosition == "top_center" ? position.top_center : tablePosition == "top_right" ? position.top_right : tablePosition == "middle_left" ? position.middle_left : tablePosition == "middle_center" ? position.middle_center : tablePosition == "middle_right" ? position.middle_right : tablePosition == "bottom_left" ? position.bottom_left : tablePosition == "bottom_center" ? position.bottom_center : position.bottom_right
    var table sonarTable = table.new(position = tablePos, columns = 2, rows = 7, bgcolor = color.new(color.white, 5), border_width = 1, border_color = color.black)
    
    // Clear table
    table.clear(sonarTable, 0, 0, 1, 6)
    
    // Header
    table.cell(sonarTable, 0, 0, "Liquidity Sonar", text_color = color.black, text_size = size.small, bgcolor = color.new(color.white, 5))
    table.cell(sonarTable, 1, 0, "Distance", text_color = color.black, text_size = size.small, bgcolor = color.new(color.white, 5))
    
    // Sonar Layout: Center to extremes (high to low)
    table.cell(sonarTable, 0, 1, "W. High", text_color = color.black, text_size = size.tiny, bgcolor = color.new(color.white, 5))
    table.cell(sonarTable, 1, 1, str.tostring(distToWeeklyHigh, "#.#") + " pts", text_color = color.black, text_size = size.tiny, bgcolor = color.new(color.white, 5))
    
    table.cell(sonarTable, 0, 2, "Daily H", text_color = color.black, text_size = size.tiny, bgcolor = color.new(color.white, 5))
    table.cell(sonarTable, 1, 2, str.tostring(distToDailyHigh, "#.#") + " pts", text_color = color.black, text_size = size.tiny, bgcolor = color.new(color.white, 5))
    
    table.cell(sonarTable, 0, 3, "Pr D H", text_color = color.black, text_size = size.tiny, bgcolor = color.new(color.white, 5))
    table.cell(sonarTable, 1, 3, str.tostring(distToPrevDailyHigh, "#.#") + " pts", text_color = color.black, text_size = size.tiny, bgcolor = color.new(color.white, 5))
    
    table.cell(sonarTable, 0, 4, "Pr D L", text_color = color.black, text_size = size.tiny, bgcolor = color.new(color.white, 5))
    table.cell(sonarTable, 1, 4, str.tostring(distToPrevDailyLow, "#.#") + " pts", text_color = color.black, text_size = size.tiny, bgcolor = color.new(color.white, 5))
    
    table.cell(sonarTable, 0, 5, "Daily L", text_color = color.black, text_size = size.tiny, bgcolor = color.new(color.white, 5))
    table.cell(sonarTable, 1, 5, str.tostring(distToDailyLow, "#.#") + " pts", text_color = color.black, text_size = size.tiny, bgcolor = color.new(color.white, 5))
    
    table.cell(sonarTable, 0, 6, "W. Low", text_color = color.black, text_size = size.tiny, bgcolor = color.new(color.white, 5))
    table.cell(sonarTable, 1, 6, str.tostring(distToWeeklyLow, "#.#") + " pts", text_color = color.black, text_size = size.tiny, bgcolor = color.new(color.white, 5))