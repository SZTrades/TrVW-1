//@version=6
indicator('SZT T3 MTF', shorttitle='T3 MTF', overlay=true, max_lines_count=500)

// Higher timeframe selection
htfResolution = input.string('60', 'Higher timeframe', group='HTF Source', tooltip='Resolution used to compute the T3 (e.g. 60 = 1h).')
confirmOnClose = input.bool(true, 'Use confirmed HTF close', group='HTF Source', tooltip='When enabled, only closed HTF bars update the T3. Otherwise it streams intra-bar.')
lookaheadMode = confirmOnClose ? barmerge.lookahead_on : barmerge.lookahead_off
gapsMode = barmerge.gaps_off

// T3 parameters
lengthT3 = input.int(5, 'Length', minval=1, group='T3 Settings')
factorT3 = input.float(0.7, 'Factor', minval=0.0, maxval=1.0, group='T3 Settings')
src = input.source(close, 'Source', group='T3 Settings')
showSlopeColor = input.bool(true, 'Color by slope', group='T3 Settings')

// Display
showBaseline = input.bool(true, 'Show T3 line', group='Display')
lineColorUp = input.color(color.new(color.green, 0), 'Color Up', group='Display')
lineColorDown = input.color(color.new(color.red, 0), 'Color Down', group='Display')
lineColorFlat = input.color(color.new(color.yellow, 0), 'Color Flat', group='Display')
defaultLineColor = input.color(color.new(color.teal, 0), 'Color No Slope', group='Display')
showBands = input.bool(false, 'Show +/- factor bands', group='Display')
bandColor = input.color(color.new(color.blue, 70), 'Band fill', group='Display')
lineWidth = input.int(2, 'Line width', minval=1, maxval=5, group='Display')

tickerInput = input.string('', 'Symbol (blank = current)', group='HTF Source', tooltip='Optional: override symbol for the HTF calculation.')
symbolToUse = tickerInput == '' ? syminfo.tickerid : tickerInput
htfSrc = request.security(symbolToUse, htfResolution, src, lookahead=lookaheadMode, gaps=gapsMode)

getT3(series, len) =>
    e1 = ta.ema(series, len)
    e2 = ta.ema(e1, len)
    e3 = ta.ema(e2, len)
    e4 = ta.ema(e3, len)
    e5 = ta.ema(e4, len)
    e6 = ta.ema(e5, len)
    c1 = -factorT3 * factorT3 * factorT3
    c2 = 3 * factorT3 * factorT3 + 3 * factorT3 * factorT3 * factorT3
    c3 = -6 * factorT3 * factorT3 - 3 * factorT3 - 3 * factorT3 * factorT3 * factorT3
    c4 = 1 + 3 * factorT3 + factorT3 * factorT3 + factorT3 * factorT3 * factorT3
    c1 * e6 + c2 * e5 + c3 * e4 + c4 * e3

t3 = getT3(htfSrc, lengthT3)

slopeUp = t3 > t3[1]
slopeDown = t3 < t3[1]
lineColor = showSlopeColor ? slopeUp ? lineColorUp : slopeDown ? lineColorDown : lineColorFlat : defaultLineColor

plot(showBaseline ? t3 : na, title='T3 HTF', color=lineColor, linewidth=lineWidth, style=plot.style_line, trackprice=true, scale=scale.right)

var float bandUpper = na
var float bandLower = na
if showBands
    bandUpper := t3 + factorT3
    bandLower := t3 - factorT3
else
    bandUpper := na
    bandLower := na

bandTopPlot = plot(showBands ? bandUpper : na, title='Upper Band', color=color.new(lineColor, 60), linewidth=1, scale=scale.right)
bandBottomPlot = plot(showBands ? bandLower : na, title='Lower Band', color=color.new(lineColor, 60), linewidth=1, scale=scale.right)
fill(bandTopPlot, bandBottomPlot, color=showBands ? bandColor : na)
