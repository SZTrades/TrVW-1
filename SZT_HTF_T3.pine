//@version=6
// SZT HTF T3 — computes the classic DaviddTech T3 filter strictly on higher-timeframe closes.
// Original T3 concept © DaviddTech, licensed under CC BY-NC-SA 4.0.

indicator("SZT HTF T3", shorttitle="SZT HTF T3", overlay=true, max_lines_count=500)

// ─────────────────────────────────────────────
// Inputs
// ─────────────────────────────────────────────
htfResolution = input.timeframe("5", "Higher timeframe (minutes)", tooltip="All calculations use only confirmed bars from this resolution.")
lengthT3 = input.int(5, "T3 length", minval=1, tooltip="Applies on the higher timeframe series.")
factorT3 = input.float(0.7, "T3 factor", minval=0.0, maxval=1.0)
srcInput = input.source(close, "Source")
useHighlight = input.bool(true, "Highlight slope direction")
colorUp = input.color(color.new(color.teal, 0), "Rising color")
colorDown = input.color(color.new(color.red, 0), "Falling color")
baseColor = input.color(#6d1e7f, "Flat color")
lineWidth = input.int(2, "Line width", minval=1, maxval=5)

// ─────────────────────────────────────────────
// Helper
// ─────────────────────────────────────────────
gdT3(src, len) =>
    ta.ema(src, len) * (1 + factorT3) - ta.ema(ta.ema(src, len), len) * factorT3

// ─────────────────────────────────────────────
// Request HTF data without lookahead
// ─────────────────────────────────────────────
htfClose = request.security(syminfo.tickerid, htfResolution, close, lookahead=barmerge.lookahead_off, gaps=barmerge.gaps_off)
htfT3 = request.security(syminfo.tickerid, htfResolution, gdT3(gdT3(gdT3(srcInput, lengthT3), lengthT3), lengthT3), lookahead=barmerge.lookahead_off, gaps=barmerge.gaps_off)

// ─────────────────────────────────────────────
// Plotting
// ─────────────────────────────────────────────
t3Dir = htfT3 > htfT3[1] ? 1 : htfT3 < htfT3[1] ? -1 : 0
t3Color = useHighlight ? t3Dir >= 0 ? colorUp : colorDown : baseColor

plot(htfT3, title="HTF T3", linewidth=lineWidth, color=t3Color)

plot(htfClose, title="HTF Close (data)", color=na, display=display.data_window)
