//@version=6
// SZT HTF T3 — computes the classic DaviddTech T3 filter strictly on higher-timeframe closes.
// Original T3 concept © DaviddTech, licensed under CC BY-NC-SA 4.0.

indicator("SZT HTF T3", shorttitle="SZT HTF T3", overlay=true, max_lines_count=500, max_labels_count=10)

// ─────────────────────────────────────────────
// Inputs
// ─────────────────────────────────────────────
htfResolution = input.timeframe("5", "Higher timeframe (minutes)", tooltip="All calculations use only confirmed bars from this resolution.")
lengthT3 = input.int(5, "T3 length", minval=1, tooltip="Applies on the higher timeframe series.")
factorT3 = input.float(0.7, "T3 factor", minval=0.0, maxval=1.0)
useHighlight = input.bool(true, "Highlight slope direction")
colorUp = input.color(color.new(color.teal, 0), "Rising color")
colorDown = input.color(color.new(color.red, 0), "Falling color")
baseColor = input.color(#6d1e7f, "Flat color")
lineWidth = input.int(2, "Line width", minval=1, maxval=5)
maxSegments = input.int(300, "Max stored segments", minval=20, maxval=500, tooltip="Limits how many HTF-to-HTF line segments stay on chart.")

// ─────────────────────────────────────────────
// Helper
// ─────────────────────────────────────────────
gdT3(src, len) =>
    ta.ema(src, len) * (1 + factorT3) - ta.ema(ta.ema(src, len), len) * factorT3

// ─────────────────────────────────────────────
// Request HTF data without lookahead
// ─────────────────────────────────────────────
htfClose = request.security(syminfo.tickerid, htfResolution, close, lookahead=barmerge.lookahead_off, gaps=barmerge.gaps_off)
htfCloseTime = request.security(syminfo.tickerid, htfResolution, time, lookahead=barmerge.lookahead_off, gaps=barmerge.gaps_off)
htfT3 = gdT3(gdT3(gdT3(htfClose, lengthT3), lengthT3), lengthT3)

// ─────────────────────────────────────────────
// Plotting via line segments anchored at HTF closes
// ─────────────────────────────────────────────
var line[] t3Segments = array.new_line()
var float prevT3 = na
var int prevTime = na

newPoint = ta.change(htfCloseTime) != 0
if barstate.isfirst and not na(htfT3)
    prevT3 := htfT3
    prevTime := htfCloseTime

if newPoint and not na(htfT3)
    currT3 = htfT3
    currTime = htfCloseTime
    if not na(prevT3) and not na(prevTime)
        segmentColor = useHighlight ? (currT3 >= prevT3 ? colorUp : colorDown) : baseColor
        ln = line.new(x1=prevTime, y1=prevT3, x2=currTime, y2=currT3, xloc=xloc.bar_time, extend=extend.none, color=segmentColor, width=lineWidth)
        array.push(t3Segments, ln)
        if array.size(t3Segments) > maxSegments
            old = array.shift(t3Segments)
            line.delete(old)
    prevT3 := currT3
    prevTime := currTime

plot(htfT3, title="HTF T3 (data)", color=na, display=display.data_window)
plot(htfClose, title="HTF Close (data)", color=na, display=display.data_window)
