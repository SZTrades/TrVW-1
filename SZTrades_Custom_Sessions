            line.new(s2_start_bar, midpoint, bar_index, midpoint, xloc = xloc.bar_index, color = MidLineColor, style = MidLineStyle, width = MidLineWidth)
    
    if s3_active and session3_enabled and s3_in_session
        box.delete(s3_current_box)
        box.delete(s3_current_body)
        
        candle_long = close > s3_open
        fillColor = candle_long ? bullColor : bearColor
        
        if BoxShow
            s3_current_box := box.new(left = s3_start_bar, top = s3_high, right = bar_index, bottom = s3_low, border_width = BoxWidth, border_style = BoxLineStyle, border_color = BoxColor, bgcolor = BodyShow ? na : fillColor)
        
