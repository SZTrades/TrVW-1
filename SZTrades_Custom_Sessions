            box.new(left = s3_start_bar, top = s3_high, right = bar_index_end, bottom = s3_low, border_width = BoxWidth, border_style = BoxLineStyle, border_color = BoxColor, bgcolor = BodyShow ? na : fillColor)
        
        if BodyShow
            if candle_long
                box.new(left = s3_start_bar, top = bar_close, right = bar_index_end, bottom = s3_open, border_width = BodyWidth, border_style = BodyLineStyle, border_color = BodyColor, bgcolor = fillColor)
            else
                box.new(left = s3_start_bar, top = s3_open, right = bar_index_end, bottom = bar_close, border_width = BodyWidth, border_style = BodyLineStyle, border_color = BodyColor, bgcolor = fillColor)
        
        if BoxRangePips
            r1 = math.abs(s3_high - s3_low) * div
            r2 = math.abs(s3_open - bar_close) * div
            r3 = r1 != 0 ? r2 / r1 : 0
            label_text = BoxRangePercentage ? str.tostring(r2, '#,##0.0#') + ' / ' + str.tostring(r1, '#,##0.0#') + ' = ' + str.tostring(r3, '0%') : str.tostring(r1, '#,##0.0#')
            label.new(s3_start_bar + (bar_index_end - s3_start_bar) / 2, s3_high + syminfo.mintick * 30, label_text, style = label.style_none, textcolor = BoxRangeTC, textalign = text.align_right)
        
            if MidLineShow
                midpoint = math.avg(s3_low, s3_high)
                line.new(s3_start_bar, midpoint, bar_index_end, midpoint, xloc = xloc.bar_index, color = MidLineColor, style = MidLineStyle, width = MidLineWidth)
        
        s3_active := false

// === REAL-TIME UPDATES ===
if barstate.islast
    if s1_active and session1_enabled and s1_in_session
        box.delete(s1_current_box)
        box.delete(s1_current_body)
        
        candle_long = close > s1_open
        fillColor = candle_long ? bullColor : bearColor
        
        if BoxShow
            s1_current_box := box.new(left = s1_start_bar, top = s1_high, right = bar_index, bottom = s1_low, border_width = BoxWidth, border_style = BoxLineStyle, border_color = BoxColor, bgcolor = BodyShow ? na : fillColor)
        
        if BodyShow
            if candle_long
                s1_current_body := box.new(left = s1_start_bar, top = close, right = bar_index, bottom = s1_open, border_width = BodyWidth, border_style = BodyLineStyle, border_color = BodyColor, bgcolor = fillColor)
            else
                s1_current_body := box.new(left = s1_start_bar, top = s1_open, right = bar_index, bottom = close, border_width = BodyWidth, border_style = BodyLineStyle, border_color = BodyColor, bgcolor = fillColor)
        
        if BoxRangePips
            r1 = math.abs(s1_high - s1_low) * div
            r2 = math.abs(s1_open - close) * div
            r3 = r1 != 0 ? r2 / r1 : 0
            label_text = BoxRangePercentage ? str.tostring(r2, '#,##0.0#') + ' / ' + str.tostring(r1, '#,##0.0#') + ' = ' + str.tostring(r3, '0%') : str.tostring(r1, '#,##0.0#')
            label.new(s1_start_bar + (bar_index - s1_start_bar) / 2, s1_high + syminfo.mintick * 30, label_text, style = label.style_none, textcolor = BoxRangeTC, textalign = text.align_right)
        
        if MidLineShow
            midpoint = math.avg(s1_low, s1_high)
            line.new(s1_start_bar, midpoint, bar_index, midpoint, xloc = xloc.bar_index, color = MidLineColor, style = MidLineStyle, width = MidLineWidth)
    
    if s2_active and session2_enabled and s2_in_session
        box.delete(s2_current_box)
        box.delete(s2_current_body)
        
        candle_long = close > s2_open
        fillColor = candle_long ? bullColor : bearColor
        
        if BoxShow
            s2_current_box := box.new(left = s2_start_bar, top = s2_high, right = bar_index, bottom = s2_low, border_width = BoxWidth, border_style = BoxLineStyle, border_color = BoxColor, bgcolor = BodyShow ? na : fillColor)
        
        if BodyShow
            if candle_long
                s2_current_body := box.new(left = s2_start_bar, top = close, right = bar_index, bottom = s2_open, border_width = BodyWidth, border_style = BodyLineStyle, border_color = BodyColor, bgcolor = fillColor)
            else
                s2_current_body := box.new(left = s2_start_bar, top = s2_open, right = bar_index, bottom = close, border_width = BodyWidth, border_style = BodyLineStyle, border_color = BodyColor, bgcolor = fillColor)
        
        if BoxRangePips
            r1 = math.abs(s2_high - s2_low) * div
            r2 = math.abs(s2_open - close) * div
            r3 = r1 != 0 ? r2 / r1 : 0
            label_text = BoxRangePercentage ? str.tostring(r2, '#,##0.0#') + ' / ' + str.tostring(r1, '#,##0.0#') + ' = ' + str.tostring(r3, '0%') : str.tostring(r1, '#,##0.0#')
            label.new(s2_start_bar + (bar_index - s2_start_bar) / 2, s2_high + syminfo.mintick * 30, label_text, style = label.style_none, textcolor = BoxRangeTC, textalign = text.align_right)
        
