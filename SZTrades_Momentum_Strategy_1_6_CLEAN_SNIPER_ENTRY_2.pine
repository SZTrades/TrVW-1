//@version=6
strategy("SZTrades v1.7 CLEAN REACTIVE", overlay=true, pyramiding=0,
     default_qty_type=strategy.percent_of_equity, default_qty_value=100,
     process_orders_on_close=true, calc_on_every_tick=false)

//────────────────────────────────────────────
// Inputs (mínimos reales)
//────────────────────────────────────────────
t3Len = input.int(4, "T3 Length")
factorT3 = input.float(0.7, "T3 Factor")

emaLen = input.int(50, "Trend EMA")
emaSlopeBars = input.int(5, "EMA Slope Bars")

flowLen = input.int(16, "Flow EMA Length")

atrLen = input.int(14, "ATR Length")
atrMaLen = input.int(20, "ATR MA Length")
atrMin = input.float(2.0, "ATR Min Gate")
atrHot = input.float(8.0, "ATR Hot Market")

stopPoints = input.float(4.0, "Stop")
tpMult = input.float(2.0, "TP Mult")

cooldownBars = input.int(4, "Cooldown")

tradeSession = input.session("0800-0900", "Session")
tz = input.string("Etc/GMT+4", "Timezone")
sessionWarmupBars = input.int(2, "Session Warmup Bars")
maxOpenRangeMult = input.float(1.8, "Max Early Range Mult")

//────────────────────────────────────────────
// Core T3
//────────────────────────────────────────────
t3(src, len) => ta.ema(src, len) * (1 + factorT3) - ta.ema(ta.ema(src, len), len) * factorT3

t3v = t3(t3(t3(close, t3Len), t3Len), t3Len)
t3Up = t3v > t3v[1]
t3Dn = t3v < t3v[1]

//────────────────────────────────────────────
// Trend + minimal regime
//────────────────────────────────────────────
ema = ta.ema(close, emaLen)
trendLong = close > ema
trendShort = close < ema
emaSlope = ema - ema[emaSlopeBars]

barRange = math.max(high - low, syminfo.mintick)
avgRange = ta.sma(barRange, atrMaLen)
rangeExpansionOk = not na(avgRange) and barRange > avgRange and math.abs(emaSlope) > 0

trendDirectionalLong = trendLong and t3Up and emaSlope > 0
trendDirectionalShort = trendShort and t3Dn and emaSlope < 0
regimeLongOk = trendDirectionalLong and rangeExpansionOk
regimeShortOk = trendDirectionalShort and rangeExpansionOk

//────────────────────────────────────────────
// Flow proxy (realistic lightweight delta)
//────────────────────────────────────────────
closePos = (close - open) / math.max(high - low, syminfo.mintick)
deltaProxy = closePos * volume
flow = ta.ema(deltaProxy, flowLen)
bullFlow = flow > 0
bearFlow = flow < 0

//────────────────────────────────────────────
// Volatility hard gate
//────────────────────────────────────────────
atr = ta.atr(atrLen)
atrMA = ta.sma(atr, atrMaLen)
atrMinOk = atr >= atrMin
atrActiveOk = atr > atrMA
hotMarket = atr >= atrHot
volOk = atrMinOk and (hotMarket or atrActiveOk)

//────────────────────────────────────────────
// Session + micro-noise cleanup
//────────────────────────────────────────────
inSession = not na(time(timeframe.period, tradeSession, tz))
sessionStart = inSession and not inSession[1]
var int sessionBars = 0
if sessionStart
    sessionBars := 1
else if inSession
    sessionBars += 1
else
    sessionBars := 0

earlyRangeAvg = ta.sma(barRange, 20)
anomalousEarlyRange = inSession and sessionBars <= sessionWarmupBars and not na(earlyRangeAvg) and barRange > earlyRangeAvg * maxOpenRangeMult
sessionCleanOk = inSession and sessionBars > sessionWarmupBars and not anomalousEarlyRange

//────────────────────────────────────────────
// Cooldown
//────────────────────────────────────────────
var int lastTrade = na
cooldownOk = na(lastTrade) or (bar_index - lastTrade > cooldownBars)

//────────────────────────────────────────────
// Signals (minimal reactive stack)
// trend + flow + regime + hard vol + clean session
//────────────────────────────────────────────
longSignal =
     sessionCleanOk and
     cooldownOk and
     regimeLongOk and
     bullFlow and
     volOk and
     barstate.isconfirmed

shortSignal =
     sessionCleanOk and
     cooldownOk and
     regimeShortOk and
     bearFlow and
     volOk and
     barstate.isconfirmed

//────────────────────────────────────────────
// Entries
//────────────────────────────────────────────
if longSignal and strategy.position_size == 0
    strategy.entry("L", strategy.long)
    lastTrade := bar_index

if shortSignal and strategy.position_size == 0
    strategy.entry("S", strategy.short)
    lastTrade := bar_index

//────────────────────────────────────────────
// Risk (modular for future structural SL transition)
//────────────────────────────────────────────
longStop = strategy.position_avg_price - stopPoints
longTP   = strategy.position_avg_price + stopPoints * tpMult

shortStop = strategy.position_avg_price + stopPoints
shortTP   = strategy.position_avg_price - stopPoints * tpMult

strategy.exit("LX", "L", stop=longStop, limit=longTP)
strategy.exit("SX", "S", stop=shortStop, limit=shortTP)

//────────────────────────────────────────────
// Visual
//────────────────────────────────────────────
plot(t3v, color=color.orange)
plot(ema, color=color.aqua)
