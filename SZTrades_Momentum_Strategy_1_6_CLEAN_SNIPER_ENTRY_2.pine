//@version=6
// SZTrades Momentum Alignment Strategy (CLEAN SNIPER)

strategy(
    "SZTrades Momentum Alignment Strategy (CLEAN SNIPER)",
    shorttitle="SZT-CLEAN",
    overlay=true,
    pyramiding=0,
    default_qty_type=strategy.percent_of_equity,
    default_qty_value=100,
    calc_on_every_tick=false,
    process_orders_on_close=true,
    commission_type=strategy.commission.percent,
    commission_value=0.01,
    slippage=1
)

// ---------------------------------------------------------------------------
// Base inputs
// ---------------------------------------------------------------------------
lengthT3 = input.int(4, "T3 Length", minval=1, group="Base - T3")
factorT3 = input.float(0.7, "T3 Factor", minval=0.0, maxval=1.0, group="Base - T3")
cumulationLength = input.int(16, "CVD Cumulation Length", minval=1, group="Base - CVD")
baseCvdThreshold = input.float(0.0, "Base CVD Threshold", minval=0.0, group="Base - CVD")

stopPoints = input.float(4.0, "Stop Points", minval=0.0, group="Risk")
takeProfitMultiplier = input.float(2.0, "Take Profit Multiplier", minval=0.1, group="Risk")
slippageTicks = input.int(1, "Slippage Ticks", minval=0, group="Risk")

tradeSession = input.session("0800-0900", "Trading Window (HHMM-HHMM)", group="Session")
sessionTimezone = input.string("Etc/GMT+4", "Timezone", group="Session")

// ---------------------------------------------------------------------------
// Clean sniper filters
// ---------------------------------------------------------------------------
trendEmaLen = input.int(50, "Trend EMA Length", minval=1, group="Sniper - Trend")
htfRegimeTf = input.timeframe("15", "HTF Regime Timeframe", group="Sniper - Trend")
htfEmaLen = input.int(100, "HTF EMA Length", minval=1, group="Sniper - Trend")

confirmBreakLookback = input.int(3, "Entry Break Lookback", minval=2, group="Sniper - Entry")
breakoutBufferAtrFrac = input.float(0.05, "Breakout Buffer ATR %", minval=0.0, step=0.01, group="Sniper - Entry")
qualityMinScore = input.int(3, "Min Quality Score", minval=1, maxval=5, group="Sniper - Entry")

cooldownBars = input.int(4, "Cooldown Bars Between Trades", minval=0, group="Sniper - Frequency")
maxTradesPerBlock = input.int(1, "Max Trades Per Session Block", minval=1, group="Sniper - Frequency")

rangeFastLen = input.int(20, "Range Fast Length", minval=2, group="Sniper - Volatility")
rangeSlowLen = input.int(60, "Range Slow Length", minval=5, group="Sniper - Volatility")
rangeExpansionMin = input.float(0.9, "Range Expansion Min", minval=0.1, step=0.05, group="Sniper - Volatility")
regimeAtrLen = input.int(14, "Regime ATR Length", minval=1, group="Sniper - Volatility")
regimeAtrMaLen = input.int(20, "Regime ATR MA Length", minval=1, group="Sniper - Volatility")
regimeSlopeBars = input.int(5, "Regime EMA Slope Bars", minval=1, group="Sniper - Volatility")
breakoutRangeMult = input.float(1.05, "Breakout Range Mult", minval=0.5, step=0.05, group="Sniper - Volatility")

chopMinAtrCompression = input.float(0.95, "Min ATR Compression", minval=0.1, step=0.05, group="Sniper - Chop")
chopMinBodyToRange = input.float(0.35, "Min Body/Range", minval=0.05, maxval=1.0, step=0.05, group="Sniper - Chop")
chopMinBodyToAtr = input.float(0.2, "Min Body/ATR", minval=0.05, step=0.05, group="Sniper - Chop")
chopMinRangeToAtr = input.float(0.6, "Min Range/ATR", minval=0.1, step=0.05, group="Sniper - Chop")

// ---------------------------------------------------------------------------
// Helper / core functions
// ---------------------------------------------------------------------------
gdT3(src, len) =>
    ta.ema(src, len) * (1 + factorT3) - ta.ema(ta.ema(src, len), len) * factorT3

// ---------------------------------------------------------------------------
// Base core logic (kept intact)
// ---------------------------------------------------------------------------
t3 = gdT3(gdT3(gdT3(close, lengthT3), lengthT3), lengthT3)
t3Direction = t3 > t3[1] ? 1 : t3 < t3[1] ? -1 : 0
t3Color = t3Direction > 0 ? color.green : color.red
basicLongT3 = t3Direction > 0 and close > t3
basicShortT3 = t3Direction < 0 and close < t3

upperWick = close > open ? high - close : high - open
lowerWick = close > open ? open - low : close - low
spread = math.max(high - low, syminfo.mintick)
bodyLength = spread - (upperWick + lowerWick)
percentUpper = upperWick / spread
percentLower = lowerWick / spread
percentBody = bodyLength / spread
halfWicks = (percentUpper + percentLower) / 2
buyingVolume = close > open ? (percentBody + halfWicks) * volume : halfWicks * volume
sellingVolume = close < open ? (percentBody + halfWicks) * volume : halfWicks * volume
cumBuy = ta.ema(buyingVolume, cumulationLength)
cumSell = ta.ema(sellingVolume, cumulationLength)
cvdDelta = cumBuy - cumSell
bullCVD = cvdDelta > baseCvdThreshold
bearCVD = cvdDelta < -baseCvdThreshold

bullAligned = basicLongT3 and bullCVD
bearAligned = basicShortT3 and bearCVD
newBull = bullAligned and not bullAligned[1] and barstate.isconfirmed
newBear = bearAligned and not bearAligned[1] and barstate.isconfirmed

// ---------------------------------------------------------------------------
// Session + 06:00 bias + block controls
// ---------------------------------------------------------------------------
inTradeBlock = not na(time(timeframe.period, tradeSession, sessionTimezone))
blockStarted = inTradeBlock and not inTradeBlock[1]
blockEnded = not inTradeBlock and inTradeBlock[1]

isSixAMBar = hour(time, sessionTimezone) == 6 and minute(time, sessionTimezone) == 0
var float open6am = na
if isSixAMBar
    open6am := open
if ta.change(time("D")) != 0
    open6am := na

allowLongBySixOpen = not na(open6am) and close > open6am
allowShortBySixOpen = not na(open6am) and close < open6am

sessionCore = array.get(str.split(tradeSession, ":"), 0)
sessionRanges = str.split(sessionCore, ",")
lastRange = array.size(sessionRanges) > 0 ? array.get(sessionRanges, array.size(sessionRanges) - 1) : ""
rangeParts = str.split(lastRange, "-")
endToken = array.size(rangeParts) > 1 ? array.get(rangeParts, 1) : ""
endTokenClean = str.replace_all(endToken, ":", "")
hasValidEnd = str.length(endTokenClean) >= 4
endHourRaw = hasValidEnd ? str.tonumber(str.substring(endTokenClean, 0, 2)) : na
endMinuteRaw = hasValidEnd ? str.tonumber(str.substring(endTokenClean, 2, 4)) : na
sessionEndHour = hasValidEnd and not na(endHourRaw) ? int(endHourRaw) : 0
sessionEndMinute = hasValidEnd and not na(endMinuteRaw) ? int(endMinuteRaw) : 0
sessionEndMinuteOfDay = sessionEndHour * 60 + sessionEndMinute
barCloseMinuteOfDay = hour(time_close, sessionTimezone) * 60 + minute(time_close, sessionTimezone)
lastBarOfBlockByClock = inTradeBlock and barCloseMinuteOfDay == sessionEndMinuteOfDay
lastBarOfBlock = hasValidEnd ? lastBarOfBlockByClock : blockEnded

// ---------------------------------------------------------------------------
// Gate stack
// ---------------------------------------------------------------------------
barRange = math.max(high - low, syminfo.mintick)
avgRecentRange = ta.sma(barRange, rangeFastLen)
avgBaselineRange = ta.sma(barRange, rangeSlowLen)
rangeExpansionOk = not na(avgRecentRange) and not na(avgBaselineRange) and avgRecentRange >= avgBaselineRange * rangeExpansionMin

trendEma = ta.ema(close, trendEmaLen)
trendLongOk = close > trendEma
trendShortOk = close < trendEma
trendSlope = trendEma - trendEma[regimeSlopeBars]

htfEma = request.security(syminfo.tickerid, htfRegimeTf, ta.ema(close, htfEmaLen), barmerge.gaps_off, barmerge.lookahead_off)
htfLongOk = close > htfEma
htfShortOk = close < htfEma

regimeAtr = ta.atr(regimeAtrLen)
regimeAtrMa = ta.sma(regimeAtr, regimeAtrMaLen)
atrTrendOk = not na(regimeAtrMa) and regimeAtr > regimeAtrMa and regimeAtr > regimeAtr[1]

breakoutRangeExpansion = rangeExpansionOk and not na(avgRecentRange) and barRange >= avgRecentRange * breakoutRangeMult
volatilityRegimeOkLong = (atrTrendOk and trendSlope > 0) or breakoutRangeExpansion
volatilityRegimeOkShort = (atrTrendOk and trendSlope < 0) or breakoutRangeExpansion

bodyAbs = math.abs(close - open)
bodyToRange = barRange > 0 ? bodyAbs / barRange : 0.0
bodyToAtr = regimeAtr > 0 ? bodyAbs / regimeAtr : 0.0
rangeToAtr = regimeAtr > 0 ? barRange / regimeAtr : 0.0
atrCompression = not na(regimeAtrMa) and regimeAtrMa > 0 ? regimeAtr / regimeAtrMa : na
chopFilterOk = not na(atrCompression) and atrCompression >= chopMinAtrCompression and bodyToRange >= chopMinBodyToRange and bodyToAtr >= chopMinBodyToAtr and rangeToAtr >= chopMinRangeToAtr

breakoutBuffer = regimeAtr * breakoutBufferAtrFrac
breakoutLongLevel = ta.highest(high, confirmBreakLookback)[1]
breakoutShortLevel = ta.lowest(low, confirmBreakLookback)[1]
breakConfirmLong = high > breakoutLongLevel and close >= breakoutLongLevel + breakoutBuffer
breakConfirmShort = low < breakoutShortLevel and close <= breakoutShortLevel - breakoutBuffer

// Regime confirmation (2 of 3 confluence)
atrExpansionRegime = not na(regimeAtrMa) and regimeAtr > regimeAtrMa and regimeAtr > regimeAtr[1]
trendSlopeLongConsistent = trendSlope != 0 and trendSlope > 0 and trendSlope[1] > 0
trendSlopeShortConsistent = trendSlope != 0 and trendSlope < 0 and trendSlope[1] < 0
breakoutRealLong = close > breakoutLongLevel
breakoutRealShort = close < breakoutShortLevel
regimeConfirmLongScore = (atrExpansionRegime ? 1 : 0) + (trendSlopeLongConsistent ? 1 : 0) + (breakoutRealLong ? 1 : 0)
regimeConfirmShortScore = (atrExpansionRegime ? 1 : 0) + (trendSlopeShortConsistent ? 1 : 0) + (breakoutRealShort ? 1 : 0)
regimeConfirmOkLong = regimeConfirmLongScore >= 2
regimeConfirmOkShort = regimeConfirmShortScore >= 2

// Micro-structure chop killer
microRangeAvg = ta.sma(barRange, 20)
microVolatilityOk = not na(microRangeAvg) and barRange > microRangeAvg * 0.7
microBodyDirectionOk = bodyToRange > 0.6
microWickOk = upperWick < 0.6 * barRange or lowerWick < 0.6 * barRange
smallBodyCount5 = ta.sum(bodyToRange < 0.4 ? 1.0 : 0.0, 5)
microAntiChopOk = smallBodyCount5 <= 3
microChopOk = microVolatilityOk and microBodyDirectionOk and microWickOk and microAntiChopOk

// ---------------------------------------------------------------------------
// Final clean signals
// ---------------------------------------------------------------------------
isFiveMinuteChart = timeframe.isminutes and timeframe.multiplier == 5

var bool enteredThisBlock = false
var bool orderPlaced = false
var int lastTradeBarIndex = na
var int winStreak = 0
var int maxWinStreak = 0
var int firstBarTime = na
var int tradesThisBlock = 0
var int trackedClosedTrades = 0
var int trackedWins = 0
var int trackedLosses = 0
var float trackedGrossProfit = 0.0
var float trackedGrossLoss = 0.0
var float trackedNetProfit = 0.0

if barstate.isfirst
    firstBarTime := time

cooldownOk = cooldownBars == 0 or na(lastTradeBarIndex) or (bar_index - lastTradeBarIndex) >= cooldownBars
blockQuotaOk = tradesThisBlock < maxTradesPerBlock

baseLongSignal = isFiveMinuteChart and inTradeBlock and newBull and allowLongBySixOpen and blockQuotaOk
baseShortSignal = isFiveMinuteChart and inTradeBlock and newBear and allowShortBySixOpen and blockQuotaOk

hardLongGate = trendLongOk and htfLongOk and volatilityRegimeOkLong and chopFilterOk and breakConfirmLong
hardShortGate = trendShortOk and htfShortOk and volatilityRegimeOkShort and chopFilterOk and breakConfirmShort

longQualityScore = (rangeExpansionOk ? 1 : 0) + (atrTrendOk ? 1 : 0) + (trendSlope > 0 ? 1 : 0) + (breakoutRangeExpansion ? 1 : 0) + (bodyToRange >= chopMinBodyToRange ? 1 : 0)
shortQualityScore = (rangeExpansionOk ? 1 : 0) + (atrTrendOk ? 1 : 0) + (trendSlope < 0 ? 1 : 0) + (breakoutRangeExpansion ? 1 : 0) + (bodyToRange >= chopMinBodyToRange ? 1 : 0)

longSignalFinal = baseLongSignal and hardLongGate and longQualityScore >= qualityMinScore and regimeConfirmOkLong and microChopOk
shortSignalFinal = baseShortSignal and hardShortGate and shortQualityScore >= qualityMinScore and regimeConfirmOkShort and microChopOk

longSignal = longSignalFinal and cooldownOk
shortSignal = shortSignalFinal and cooldownOk

// ---------------------------------------------------------------------------
// Order / position management
// ---------------------------------------------------------------------------
if blockStarted
    enteredThisBlock := false
    orderPlaced := false
    tradesThisBlock := 0
if blockEnded
    enteredThisBlock := false
    orderPlaced := false
    tradesThisBlock := 0

closedTradesNow = int(strategy.closedtrades)
newClosedTrades = closedTradesNow - trackedClosedTrades
if newClosedTrades > 0
    for tradeIdx = trackedClosedTrades to closedTradesNow - 1
        tradePnl = strategy.closedtrades.profit(tradeIdx)
        trackedNetProfit += tradePnl

        if tradePnl > 0
            trackedWins += 1
            trackedGrossProfit += tradePnl
            winStreak += 1
            maxWinStreak := math.max(maxWinStreak, winStreak)
        else
            if tradePnl < 0
                trackedLosses += 1
                trackedGrossLoss += tradePnl
            winStreak := 0

        if tradePnl >= 0
            lastTradeBarIndex := na

    trackedClosedTrades := closedTradesNow

if strategy.position_size == 0 and strategy.position_size[1] != 0
    orderPlaced := false

var float activeLongStop = na
var float activeShortStop = na
var float activeLongTP = na
var float activeShortTP = na

if longSignal and not orderPlaced and strategy.position_size == 0
    strategy.entry("Long", strategy.long)
    orderPlaced := true

if shortSignal and not orderPlaced and strategy.position_size == 0
    strategy.entry("Short", strategy.short)
    orderPlaced := true

newLong = strategy.position_size > 0 and strategy.position_size[1] == 0
newShort = strategy.position_size < 0 and strategy.position_size[1] == 0
newPositionOpened = strategy.position_size != 0 and strategy.position_size[1] == 0
stopBuffer = slippageTicks * syminfo.mintick

if newPositionOpened
    enteredThisBlock := true
    tradesThisBlock += 1
    lastTradeBarIndex := bar_index

if newLong and na(activeLongStop)
    entryPrice = strategy.position_avg_price
    activeLongStop := entryPrice - stopPoints - stopBuffer
    activeLongTP := entryPrice + stopPoints * takeProfitMultiplier
    strategy.exit("Long Exit", "Long", stop=activeLongStop, limit=activeLongTP)

if newShort and na(activeShortStop)
    entryPrice = strategy.position_avg_price
    activeShortStop := entryPrice + stopPoints + stopBuffer
    activeShortTP := entryPrice - stopPoints * takeProfitMultiplier
    strategy.exit("Short Exit", "Short", stop=activeShortStop, limit=activeShortTP)

if strategy.position_size == 0
    activeLongStop := na
    activeShortStop := na
    activeLongTP := na
    activeShortTP := na

if lastBarOfBlock and strategy.position_size != 0
    strategy.close_all(comment="Block end close")

// ---------------------------------------------------------------------------
// Visuals
// ---------------------------------------------------------------------------
bgcolor(bullAligned ? color.new(color.green, 88) : bearAligned ? color.new(color.red, 88) : na)
plot(t3, title="T3", linewidth=2, color=t3Color)
plot(open6am, title="06:00 Open", color=color.new(color.yellow, 0), linewidth=2, style=plot.style_linebr)
plot(trendEma, title="Trend EMA", color=color.new(color.aqua, 0), linewidth=1)
plot(htfEma, title="HTF EMA", color=color.new(color.orange, 0), linewidth=1)

plotshape(newBull, title="Bull Alignment", location=location.belowbar, style=shape.triangleup, color=color.new(color.green, 0), size=size.tiny)
plotshape(newBear, title="Bear Alignment", location=location.abovebar, style=shape.triangledown, color=color.new(color.red, 0), size=size.tiny)

// ---------------------------------------------------------------------------
// Metrics table
// ---------------------------------------------------------------------------
var table stats = table.new(position.top_right, 2, 11, border_width=1)
if barstate.islast
    closedTrades = trackedClosedTrades
    winRate = closedTrades > 0 ? (trackedWins * 100.0) / closedTrades : na
    profitFactor = trackedGrossLoss != 0 ? trackedGrossProfit / math.abs(trackedGrossLoss) : na
    netProfit = trackedNetProfit
    maxDrawdown = strategy.max_drawdown
    riskUnit = math.max(strategy.initial_capital * 0.01, 1.0)
    expectancy = netProfit / riskUnit
    elapsedDays = not na(firstBarTime) ? math.max((time - firstBarTime) / 86400000.0, 1.0) : 1.0
    tradesPerDay = closedTrades / elapsedDays
    avgPnlPerTrade = closedTrades > 0 ? netProfit / closedTrades : na

    table.cell(stats, 0, 0, "Trades", text_color=color.white, bgcolor=color.new(color.black, 0))
    table.cell(stats, 1, 0, str.tostring(closedTrades), text_color=color.white, bgcolor=color.new(color.black, 0))

    table.cell(stats, 0, 1, "Winrate %", text_color=color.white, bgcolor=color.new(color.black, 0))
    table.cell(stats, 1, 1, str.tostring(winRate, "#.##"), text_color=color.white, bgcolor=color.new(color.black, 0))

    table.cell(stats, 0, 2, "PF", text_color=color.white, bgcolor=color.new(color.black, 0))
    table.cell(stats, 1, 2, str.tostring(profitFactor, "#.##"), text_color=color.white, bgcolor=color.new(color.black, 0))

    table.cell(stats, 0, 3, "Net profit", text_color=color.white, bgcolor=color.new(color.black, 0))
    table.cell(stats, 1, 3, str.tostring(netProfit, "#.##"), text_color=color.white, bgcolor=color.new(color.black, 0))

    table.cell(stats, 0, 4, "Expectancy", text_color=color.white, bgcolor=color.new(color.black, 0))
    table.cell(stats, 1, 4, str.tostring(expectancy, "#.##"), text_color=color.white, bgcolor=color.new(color.black, 0))

    table.cell(stats, 0, 5, "Max DD", text_color=color.white, bgcolor=color.new(color.black, 0))
    table.cell(stats, 1, 5, str.tostring(maxDrawdown, "#.##"), text_color=color.white, bgcolor=color.new(color.black, 0))

    table.cell(stats, 0, 6, "Trades/day", text_color=color.white, bgcolor=color.new(color.black, 0))
    table.cell(stats, 1, 6, str.tostring(tradesPerDay, "#.##"), text_color=color.white, bgcolor=color.new(color.black, 0))

    table.cell(stats, 0, 7, "Win streak max", text_color=color.white, bgcolor=color.new(color.black, 0))
    table.cell(stats, 1, 7, str.tostring(maxWinStreak), text_color=color.white, bgcolor=color.new(color.black, 0))

    table.cell(stats, 0, 8, "Avg PnL/trade", text_color=color.white, bgcolor=color.new(color.black, 0))
    table.cell(stats, 1, 8, str.tostring(avgPnlPerTrade, "#.##"), text_color=color.white, bgcolor=color.new(color.black, 0))

    table.cell(stats, 0, 9, "Block trades", text_color=color.white, bgcolor=color.new(color.black, 0))
    table.cell(stats, 1, 9, str.tostring(tradesThisBlock), text_color=color.white, bgcolor=color.new(color.black, 0))

    table.cell(stats, 0, 10, "QScore L/S", text_color=color.white, bgcolor=color.new(color.black, 0))
    table.cell(stats, 1, 10, str.tostring(longQualityScore) + "/" + str.tostring(shortQualityScore), text_color=color.white, bgcolor=color.new(color.black, 0))
