summary.head(10)def summarize_trades(trades: List[Trade]) -> pd.DataFrame:
    if not trades:
        return pd.DataFrame(columns=["date","dir","entry","exit","outcome","R"]).set_index("date")
    df = pd.DataFrame([
        {
            "date": t.session_date,
            "dir": t.direction,
            "entry_ts": t.entry_ts,
            "exit_ts": t.exit_ts,
            "entry": t.entry_px,
            "exit": t.exit_px,
            "tp": t.tp_px,
            "sl": t.sl_px,
            "outcome": t.outcome,
            "R": t.r_multiple,
        }
        for t in trades
    ])
    df = df.set_index("date").sort_index()
    return df


def metrics_and_plots(trades: List[Trade]):
    summ = summarize_trades(trades)
    if summ.empty:
        print("No trades.")
        return summ

    equity = summ["R"].cumsum()
    peak = equity.cummax()
    drawdown = equity - peak

    total = len(summ)
    wins = int((summ["R"] > 0).sum())
    win_rate = wins / total if total else 0
    avg_R = float(summ["R"].mean())
    expectancy = avg_R

    print(f"Trades: {total}")
    print(f"Win rate: {win_rate:.1%}")
    print(f"Avg R: {avg_R:.3f}")
    print(f"Expectancy (R/trade): {expectancy:.3f}")
    print(f"Total R: {equity.iloc[-1]:.2f}")
    print(f"Max drawdown (R): {drawdown.min():.2f}")

    fig, ax = plt.subplots(2, 1, figsize=(12, 8), sharex=True)
    equity.plot(ax=ax[0], color="tab:blue", label="Equity (R)")
    ax[0].legend(loc="best")
    drawdown.plot(ax=ax[1], color="tab:red", label="Drawdown (R)")
    ax[1].legend(loc="best")
    plt.show()

    return summ@dataclass
class Trade:
    session_date: pd.Timestamp
    direction: str  # "long" or "short"
    entry_ts: pd.Timestamp
    entry_px: float
    tp_px: float
    sl_px: float
    exit_ts: pd.Timestamp
    exit_px: float
    outcome: str  # "TP" | "SL" | "EOD" | "NoTrade"
    r_multiple: float


def _first_breakout_row(day_df: pd.DataFrame, ib_high: float, ib_low: float) -> Optional[pd.Timestamp]:
    for ts, row in day_df.iterrows():
        hit_high = row["high"] >= ib_high
        hit_low = row["low"] <= ib_low
        if hit_high and not hit_low:
            return ts, "long"
        if hit_low and not hit_high:
            return ts, "short"
        if hit_high and hit_low:
            # tie: choose whichever is closer to open; if still tie, skip day
            dist_high = abs(row["open"] - ib_high)
            dist_low = abs(row["open"] - ib_low)
            if dist_high < dist_low:
                return ts, "long"
            if dist_low < dist_high:
                return ts, "short"
            return None
    return None


def _simulate_until_exit(
    after_entry_df: pd.DataFrame,
    direction: str,
    entry_px: float,
    tp_px: float,
    sl_px: float,
    check_sl_first: bool,
    session_end: Optional[str],
) -> Tuple[pd.Timestamp, float, str]:
    for ts, row in after_entry_df.iterrows():
        # EOD exit if this bar is beyond session end
        if session_end is not None:
            end_t = pd.to_datetime(session_end).time()
            if ts.tz_convert(ts.tz.zone).time >= end_t and ts != after_entry_df.index[0]:
                return ts, row["close"], "EOD"

        high = row["high"]
        low = row["low"]
        if direction == "long":
            if check_sl_first and low <= sl_px:
                return ts, sl_px, "SL"
            if high >= tp_px:
                return ts, tp_px, "TP"
            if (not check_sl_first) and low <= sl_px:
                return ts, sl_px, "SL"
        else:
            if check_sl_first and high >= sl_px:
                return ts, sl_px, "SL"
            if low <= tp_px:
                return ts, tp_px, "TP"
            if (not check_sl_first) and high >= sl_px:
                return ts, sl_px, "SL"

    # If we reach here, exit at last bar close
    last_ts = after_entry_df.index[-1]
    return last_ts, after_entry_df.iloc[-1]["close"], "EOD"


def backtest_first_breakout(
    df: pd.DataFrame,
    daily_ib: pd.DataFrame,
    session_end: Optional[str],
    tp_mult: float = 1.0,
    slippage_points: float = 0.0,
    commission_points: float = 0.0,
    check_sl_first: bool = True,
) -> List[Trade]:
    trades: List[Trade] = []

    ses_date = session_date_index(df.index)
    for day, ib in daily_ib.iterrows():
        day_mask = ses_date == day
        day_df = df.loc[day_mask]
        if day_df.empty:
            continue
        # filter to after IB window end
        aft_df = day_df[day_df.index > ib["ib_end_ts"]]
        if aft_df.empty:
            continue

        found = _first_breakout_row(aft_df, ib["ib_high"], ib["ib_low"])
        if not found:
            continue
        brk_ts, direction = found

        if direction == "long":
            entry_px = max(ib["ib_high"], aft_df.loc[brk_ts]["open"]) + slippage_points
            tp_px = entry_px + ib["ib_delta"] * tp_mult
            sl_px = ib["ib_low"]
        else:
            entry_px = min(ib["ib_low"], aft_df.loc[brk_ts]["open"]) - slippage_points
            tp_px = entry_px - ib["ib_delta"] * tp_mult
            sl_px = ib["ib_high"]

        after_entry_df = aft_df.loc[aft_df.index >= brk_ts]
        exit_ts, exit_px, outcome = _simulate_until_exit(
            after_entry_df,
            direction,
            entry_px,
            tp_px,
            sl_px,
            check_sl_first,
            session_end,
        )

        r = (exit_px - entry_px) / ib["ib_delta"] if direction == "long" else (entry_px - exit_px) / ib["ib_delta"]
        r -= (commission_points / ib["ib_delta"]) if commission_points > 0 else 0.0

        trades.append(
            Trade(
                session_date=day,
                direction=direction,
                entry_ts=brk_ts,
                entry_px=float(entry_px),
                tp_px=float(tp_px),
                sl_px=float(sl_px),
                exit_ts=exit_ts,
                exit_px=float(exit_px),
                outcome=outcome,
                r_multiple=float(r),
            )
        )

    return tradesdef compute_daily_ib(df: pd.DataFrame, ib_start: str, ib_end: str) -> pd.DataFrame:
    if df.empty:
        raise ValueError("Empty dataframe")

    ses_date = session_date_index(df.index)
    mask_ib = between_time_mask(df.index, ib_start, ib_end)

    records = []
    for day, day_idx in df.groupby(ses_date).groups.items():
        day_df = df.loc[day_idx]
        ib_df = day_df[mask_ib[day_idx]]
        if ib_df.empty:
            continue
        ib_high = float(np.nanmax(ib_df["high"]))
        ib_low = float(np.nanmin(ib_df["low"]))
        ib_mid = (ib_high + ib_low) / 2.0
        ib_delta = ib_high - ib_low
        if not np.isfinite(ib_delta) or ib_delta <= 0:
            continue
        ib_end_ts = ib_df.index.max()
        records.append({
            "session_date": day,
            "ib_high": ib_high,
            "ib_low": ib_low,
            "ib_mid": ib_mid,
            "ib_delta": ib_delta,
            "ib_end_ts": ib_end_ts,
        })

    daily = pd.DataFrame.from_records(records).set_index("session_date").sort_index()
    return dailydef _standardize_columns(df: pd.DataFrame, column_map: Dict[str, str]) -> pd.DataFrame:
    lower_map = {k.lower(): v for k, v in column_map.items()}

    col_aliases = {
        "open": ["open", "o"],
        "high": ["high", "h"],
        "low": ["low", "l"],
        "close": ["close", "c", "adj close", "adj_close"],
        "volume": ["volume", "vol", "v"],
    }

    std = {}
    for std_name, aliases in col_aliases.items():
        if std_name in lower_map:
            src = lower_map[std_name]
            if src in df.columns:
                std[std_name] = src
            else:
                # try case-insensitive match
                matches = [c for c in df.columns if c.lower() == src.lower()]
                if matches:
                    std[std_name] = matches[0]
        else:
            # infer from aliases
            matches = [c for c in df.columns if c.lower() in aliases]
            if matches:
                std[std_name] = matches[0]

    required = ["open", "high", "low", "close"]
    for r in required:
        if r not in std:
            raise ValueError(f"Missing required column for '{r}'. Found: {list(df.columns)}")

    # build a new frame with canonical names
    out = pd.DataFrame(index=df.index)
    for k, v in std.items():
        out[k] = pd.to_numeric(df[v], errors="coerce")
    if "volume" not in out:
        out["volume"] = np.nan
    return out


def load_csv_intraday(
    path: str,
    time_col: str,
    tz_local: str,
    column_map: Optional[Dict[str, str]] = None,
    start_date: Optional[str] = None,
    end_date: Optional[str] = None,
) -> pd.DataFrame:
    raw = pd.read_csv(path)
    if time_col not in raw.columns:
        # try case-insensitive
        matches = [c for c in raw.columns if c.lower() == time_col.lower()]
        if not matches:
            raise ValueError(f"Time column '{time_col}' not found. Columns: {list(raw.columns)}")
        time_col = matches[0]

    ts = pd.to_datetime(raw[time_col], errors="coerce", utc=False)
    if ts.dt.tz is None:
        # localize naive timestamps
        ts = ts.dt.tz_localize(tz_local)
    else:
        # convert to local
        ts = ts.dt.tz_convert(tz_local)

    raw.index = ts
    raw = raw.drop(columns=[time_col])
    raw = raw.sort_index()

    if start_date is not None:
        raw = raw[raw.index.normalize() >= pd.Timestamp(start_date, tz=tz_local)]
    if end_date is not None:
        raw = raw[raw.index.normalize() <= pd.Timestamp(end_date, tz=tz_local)]

    std = _standardize_columns(raw, column_map or {})
    return std


def session_date_index(ts: pd.DatetimeIndex) -> pd.Series:
    return ts.tz_convert(ts.tz.zone).normalize()


def between_time_mask(idx: pd.DatetimeIndex, start: str, end: str) -> np.ndarray:
    start_t = pd.to_datetime(start).time()
    end_t = pd.to_datetime(end).time()
    times = idx.tz_convert(idx.tz.zone).time
    if start_t <= end_t:
        return (times >= start_t) & (times < end_t)
    # overnight window
    return (times >= start_t) | (times < end_t)from __future__ import annotations

